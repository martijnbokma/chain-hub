---
export const prerender = true;
import SiteHeader from '../../components/SiteHeader.astro';
import Footer from '../../components/sections/Footer.astro';
import TerminalBlock from '../../components/docs/TerminalBlock.astro';
import Callout from '../../components/docs/Callout.astro';
import TocLink from '../../components/docs/TocLink.astro';
import SeoHead from '../../components/SeoHead.astro';

const baseUrl = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.origin ?? 'https://www.chainhub.one';

const pageTitle = 'Chain Hub documentation | CLI, CHAIN_HOME & quickstart';
const pageDescription =
  'Official Chain Hub docs: install the chain-hub npm CLI, run chain init and chain setup, learn the CHAIN_HOME layout, browse commands (add, validate, list), and local development.';

const docsJsonLd: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Home',
        item: `${siteOrigin}/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: 'Documentation',
        item: `${siteOrigin}/docs/`,
      },
    ],
  },
  {
    '@type': 'WebPage',
    name: pageTitle,
    description: pageDescription,
    url: `${siteOrigin}/docs/`,
    inLanguage: 'en',
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: `${siteOrigin}/og.png`,
      width: 1200,
      height: 630,
    },
    isPartOf: {
      '@type': 'WebSite',
      name: 'Chain Hub',
      url: `${siteOrigin}/`,
    },
  },
];

const headerNavItems = [
  { href: '#quickstart', label: 'Quickstart' },
  { href: '#what-is-a-skill', label: 'Skills' },
  { href: '#up-to-date', label: 'Updates' },
  { href: '#location', label: 'Location' },
  { href: '#install-content', label: 'Content', mobileLabel: 'Content types' },
  { href: '#concepts', label: 'Concepts' },
  { href: '#continual-learning', label: 'Learning loop' },
  { href: '#commands', label: 'Commands' },
  { href: '#local-dev', label: 'Local dev' },
  { href: '#troubleshooting', label: 'Troubleshooting', cta: true },
];

const headerMobilePrefix = [{ href: baseUrl, label: 'Home' }];

const tocItems = [
  { href: '#intro', label: 'New to Chain Hub?' },
  { href: '#what-is-a-skill', label: 'What is a skill?' },
  { href: '#first-skill', label: 'Your first skill' },
  { href: '#hub-layout', label: 'Hub layout' },
  { href: '#editor-setup', label: 'Editor setup' },
  { href: '#quickstart', label: 'Quickstart' },
  { href: '#up-to-date', label: 'Keeping your Hub up to date' },
  { href: '#location', label: 'Where is your Hub located?' },
  { href: '#install-content', label: 'Adding Knowledge' },
  { href: '#concepts', label: 'Core concepts' },
  { href: '#continual-learning', label: 'Continual learning' },
  { href: '#commands', label: 'Command overview' },
  { href: '#local-dev', label: 'Local development' },
  { href: '#troubleshooting', label: 'Troubleshooting' },
] as const;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SeoHead
    title={pageTitle}
    description={pageDescription}
    path="/docs/"
    ogType="website"
    jsonLd={docsJsonLd}
    ogImageAlt="Chain Hub documentation — CLI, CHAIN_HOME, install and commands"
  />
</head>
<body class="ch-site min-w-0 overflow-x-hidden bg-bg pb-[env(safe-area-inset-bottom,0px)] font-mono text-[13px] leading-[1.65] text-text antialiased [text-size-adjust:100%]">

<SiteHeader items={headerNavItems} mobilePrefix={headerMobilePrefix} desktopNavMode="menu" />

<div class="relative isolate min-h-dvh">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_55%_42%_at_72%_12%,rgba(139,124,255,0.11)_0%,transparent_62%),radial-gradient(ellipse_40%_36%_at_12%_28%,rgba(72,176,255,0.06)_0%,transparent_58%)]" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute inset-0 bg-[length:64px_64px] [background-image:linear-gradient(rgba(239,242,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(239,242,255,0.06)_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_85%_55%_at_50%_0%,black,transparent_72%)]"
    aria-hidden="true"
  ></div>

  <main class="layout-wrap-docs relative z-10">
    <section class="border-b border-border pb-10 pt-[calc(88px+env(safe-area-inset-top,0px))] max-[680px]:pb-8 max-[680px]:pt-[calc(76px+env(safe-area-inset-top,0px))]">
      <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Documentation</div>
      <h1 class="mb-5 font-display text-[clamp(34px,5.5vw,54px)] font-bold leading-[1.02] tracking-[-0.06em]">Docs</h1>
      <p class="max-w-[70ch] text-sm leading-[1.75] text-text-dim">
        Lightweight reference for Chain Hub — installation, the
        <code class="rounded-[5px] border border-accent/25 bg-accent/10 px-1.5 py-px text-[12px] text-code-inline">CHAIN_HOME</code> model, and core CLI commands.
      </p>
    </section>

    <div class="grid min-w-0 grid-cols-1 gap-6 pb-16 pt-8 max-md:gap-5 max-md:pb-[max(48px,env(safe-area-inset-bottom,0px))] max-md:pt-6 md:grid-cols-[248px_minmax(0,1fr)] md:gap-8 md:pb-20">
      <aside
        class="sticky top-[calc(72px+20px+env(safe-area-inset-top,0px))] hidden min-w-0 self-start rounded-[10px] border border-border-bright bg-surface p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] md:block"
        aria-label="Table of contents"
      >
        <div class="mb-3 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Contents</div>
        <ul class="m-0 flex list-none flex-col gap-1.5">
          {tocItems.map((item) => <TocLink href={item.href} label={item.label} />)}
        </ul>
      </aside>
      <div class="min-w-0">
        <details
          id="docs-toc-mobile"
          class="group/toc sticky top-[calc(68px+env(safe-area-inset-top,0px))] z-[90] mb-5 rounded-[10px] border border-border-bright bg-[rgba(12,15,26,0.92)] shadow-[inset_0_1px_0_rgba(255,255,255,0.04),0_8px_32px_rgba(0,0,0,0.35)] backdrop-blur-[14px] md:hidden"
        >
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3 px-3.5 py-3 text-[11px] font-medium uppercase tracking-[0.14em] text-text-dim transition-colors hover:text-text [&::-webkit-details-marker]:hidden"
          >
            <span class="before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Contents</span>
            <svg width="14" height="14" viewBox="0 0 12 12" fill="none" aria-hidden="true" class="shrink-0 text-text-dim transition group-open/toc:rotate-180">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
          </summary>
          <nav class="border-t border-border px-2 pb-2 pt-1" aria-label="Page sections">
            <ul class="m-0 max-h-[min(55vh,380px)] list-none space-y-0.5 overflow-y-auto overscroll-y-contain py-1">
              {tocItems.map((item) => (
                <li class="m-0">
                  <a
                    href={item.href}
                    class="block rounded-md px-2.5 py-2 text-[13px] text-text-dim no-underline transition-colors hover:bg-[rgba(139,124,255,0.1)] hover:text-text"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </details>
        <article class="ch-docs-prose min-w-0 [&_h2]:mb-3 [&_h2]:mt-0 [&_h2]:font-display [&_h2]:text-[clamp(22px,3.2vw,28px)] [&_h2]:font-bold [&_h2]:leading-[1.08] [&_h2]:tracking-[-0.04em] [&_li]:mb-1.5 [&_p]:mb-2.5 [&_p]:text-text-dim [&_section]:mb-5 [&_section]:scroll-mt-[calc(56px+24px+env(safe-area-inset-top,0px))] [&_section]:rounded-[10px] [&_section]:border [&_section]:border-border-bright [&_section]:bg-surface [&_section]:p-6 [&_section]:shadow-[inset_0_1px_0_rgba(255,255,255,0.035)] max-[680px]:[&_section]:mb-4 max-[680px]:[&_section]:p-4 [&_strong]:font-semibold [&_strong]:text-text [&_ul]:ml-[18px] [&_ul]:text-text-dim">
      <section id="intro">
      <h2>New to Chain Hub?</h2>
      <p>
        Chain Hub is a directory on your machine (<code>~/chain-hub</code>) that syncs to every AI editor you use.
        You write instructions once as Markdown files. <code>chain setup</code> creates symlinks so Cursor, Claude Code,
        Windsurf, and others load them automatically. Update a file in your hub — every editor picks it up instantly.
      </p>
      </section>

      <section id="what-is-a-skill">
        <h2>What is a skill?</h2>
        <p>
          A skill is a folder with one file — <code>SKILL.md</code>. That file tells the AI when to use the skill
          and what to do.
        </p>
        <pre class="overflow-x-auto rounded-lg border border-border bg-surface-2 p-4 text-[12px] leading-[1.7] text-text-dim">~/chain-hub/skills/
  debug/
    SKILL.md    ← one file per skill</pre>
        <p>Each <code>SKILL.md</code> has two parts: a YAML frontmatter block and a body.</p>
        <pre class="overflow-x-auto rounded-lg border border-border bg-surface-2 p-4 text-[12px] leading-[1.7] text-text-dim">---
name: debug          ← how the skill is stored and found
description: &gt;-
  Systematic debugging workflow. Use when hitting an error,
  test failure, or unexpected behavior.
                     ↑ when the AI chooses this skill (the trigger)
---

## Steps            ← what the AI does
1. Reproduce with a minimal case
2. Isolate: data, logic, or environment?
3. Fix the root cause, not the symptom
4. Add a regression test</pre>
        <Callout>
          Skills work in every linked editor — the same <code>SKILL.md</code> file is read by Cursor, Claude Code,
          Windsurf, and others after <code>chain setup</code>.
        </Callout>
      </section>

      <section id="first-skill">
        <h2>Your first skill in 5 minutes</h2>
        <ol class="ml-[18px] text-text-dim [&_li]:mb-3">
          <li>
            <strong>Scaffold a new skill</strong> — run <code>chain new my-skill</code> to create the folder and template file.
            <TerminalBlock code={`$ chain new my-skill`} />
          </li>
          <li>
            <strong>Open the file</strong> — <code>~/chain-hub/skills/my-skill/SKILL.md</code> opens in your editor.
            The template is already filled in with a name and placeholder description.
          </li>
          <li>
            <strong>Write your instructions</strong> — edit the <code>description</code> field (when to use this skill)
            and the body (what to do). Keep it focused and under 200 lines.
          </li>
          <li>
            <strong>Validate</strong> — run <code>chain validate</code> to check frontmatter and structure.
            <TerminalBlock code={`$ chain validate`} />
          </li>
          <li>
            <strong>Use it in your editor</strong> — mention the skill by name or describe the scenario it covers.
            The AI picks it up automatically from the linked directory.
          </li>
        </ol>
        <Callout>
          No restart needed — skills are loaded fresh each session. If a skill doesn't appear, run
          <code>chain setup</code> and reopen your editor.
        </Callout>
      </section>

      <section id="hub-layout">
        <h2>Hub layout</h2>
        <p>After <code>chain init</code>, your hub has this structure:</p>
        <pre class="overflow-x-auto rounded-lg border border-border bg-surface-2 p-4 text-[12px] leading-[1.7] text-text-dim">~/chain-hub/
  core/                    ← bundled skills (read-only, updated by chain init)
  skills/                  ← your skills (create and edit here)
    debug/
      SKILL.md
  rules/
    global.md              ← applies to all linked editors
  agents/                  ← agent personas
  workflows/               ← step-by-step procedures
  skills-registry.yaml     ← tracks what is installed</pre>
        <ul>
          <li><code>core/</code> — protected bundled content from the npm package; refreshed by <code>chain init</code>; do not edit directly.</li>
          <li><code>skills/</code> — your personal and registry-installed skills; edit freely.</li>
          <li><code>rules/</code> — persistent instructions loaded by all editors (e.g. coding style, language preferences).</li>
          <li><code>agents/</code> — named agent personas for focused sessions.</li>
          <li><code>workflows/</code> — step-by-step procedures for recurring tasks.</li>
          <li><code>skills-registry.yaml</code> — tracks provenance and buckets for installed skills.</li>
        </ul>
      </section>

      <section id="editor-setup">
        <h2>Editor setup</h2>
        <p>
          After <code>chain setup</code>, the <code>debug</code> skill lands or is made available depending on the editor:
        </p>
        <div class="-mx-1 overflow-x-auto overscroll-x-contain px-1 max-[560px]:mx-0 max-[560px]:overflow-visible max-[560px]:px-0">
          <table class="w-full min-w-[560px] border-collapse max-[560px]:block max-[560px]:min-w-0 [&_tbody_td]:border-b [&_tbody_td]:border-border [&_tbody_td]:px-2 [&_tbody_td]:py-2.5 [&_tbody_td]:text-left [&_tbody_td]:align-top [&_tbody_td]:text-text-dim [&_td]:max-[560px]:block [&_td]:max-[560px]:w-full [&_td]:max-[560px]:border-none [&_td]:max-[560px]:p-0 [&_td]:max-[560px]:last:text-sm [&_td]:max-[560px]:last:leading-snug [&_td_code]:max-[560px]:break-words [&_th]:max-[560px]:hidden [&_thead]:max-[560px]:hidden [&_tr]:max-[560px]:mb-2.5 [&_tr]:max-[560px]:block [&_tr]:max-[560px]:rounded-[10px] [&_tr]:max-[560px]:border [&_tr]:max-[560px]:border-border-bright [&_tr]:max-[560px]:bg-surface-2 [&_tr]:max-[560px]:p-3 [&_tr]:max-[560px]:last:mb-0 [&_tr_td:first-child]:max-[560px]:mb-2 [&_tr_td:first-child]:max-[560px]:border-b [&_tr_td:first-child]:max-[560px]:border-border [&_tr_td:first-child]:max-[560px]:pb-2">
            <thead>
              <tr>
                <th class="border-b border-border px-2 py-2.5 text-left align-top text-xs uppercase tracking-[0.08em] text-text-dim">Editor</th>
                <th class="border-b border-border px-2 py-2.5 text-left align-top text-xs uppercase tracking-[0.08em] text-text-dim">Path after <code>chain setup</code></th>
              </tr>
            </thead>
            <tbody>
              <tr><td>Claude Code</td><td><code>~/.claude/skills/debug/SKILL.md</code></td></tr>
              <tr><td>Cursor</td><td><code>~/.cursor/skills/debug/SKILL.md</code></td></tr>
              <tr><td>Windsurf</td><td><code>~/.codeium/windsurf/skills/debug/SKILL.md</code></td></tr>
              <tr><td>Antigravity</td><td><code>~/.gemini/antigravity/skills/debug/SKILL.md</code></td></tr>
              <tr><td>Gemini CLI (via Universal)</td><td><code>~/.agents/skills/debug/SKILL.md</code></td></tr>
              <tr><td>Kiro</td><td><code>~/.kiro/hooks/skills/debug/SKILL.md</code></td></tr>
              <tr><td>Trae</td><td><code>~/.trae/skills/debug/SKILL.md</code></td></tr>
              <tr><td>Mistral Vibe</td><td><code>~/.vibe/skills/debug/SKILL.md</code></td></tr>
            </tbody>
          </table>
        </div>
        <Callout>
          Run <code>chain status</code> to verify which editors are linked and whether symlinks are healthy.
        </Callout>
      </section>

      <section id="quickstart">
          <h2>Quickstart</h2>
          <p>Install from npm, initialize your hub, then link all supported IDEs.</p>
          <TerminalBlock code={`$ npm install -g chain-hub\n$ chain init\n$ chain setup\n$ chain list`} />
          <p>
            By default your hub lives at <code>~/chain-hub</code> (visible in your home folder). You can override this with
            <code>CHAIN_HOME</code> when needed.
          </p>
        </section>

        <section id="up-to-date">
          <h2>CLI and hub updates</h2>
          <p>
            The <code>chain</code> command is installed from the <code>chain-hub</code> npm package.
            Update the CLI by running the same global install as for a fresh setup:
          </p>
          <TerminalBlock code={`$ npm install -g chain-hub\n$ chain --version`} />
          <p>
            After upgrading the CLI, run <code>chain init</code> so <code>CHAIN_HOME/core/</code> matches the bundled core in that release.
            Run <code>chain setup</code> again if release notes mention IDE symlink changes.
            For skills installed from the registry or GitHub bundles, use <code>chain update</code>.
          </p>
        </section>

        <section id="location">
          <h2>Where is your Hub located?</h2>
          <p>
            By default, your knowledge hub is stored in a folder called <code>chain-hub</code> in your home directory.
            This makes it easy to find and back up your AI instructions.
          </p>
          <p>
            If you're an advanced user, you can also set a custom location using the <code>CHAIN_HOME</code> setting.
          </p>
        </section>

        <section id="install-content">
          <h2>Adding Knowledge</h2>
          <p>
            Chain Hub supports different ways to improve your AI. You can download pre-made expert "skills" or create your own custom instructions by adding files to your Hub folders.
          </p>
          <TerminalBlock code={`$ chain add github:owner/repo\n$ chain new my-skill\n$ chain setup\n$ chain validate`} />
          <ul>
            <li><strong>Skills:</strong> These are expert knowledge packs. You can download them or start a new one with <code>chain new</code>. They live in the <code>skills/</code> folder.</li>
            <li><strong>Workflows:</strong> Step-by-step guides for tasks. Add your process files to the <code>workflows/</code> folder.</li>
            <li><strong>Rules:</strong> General guidelines for tone and style. Place these in the <code>rules/</code> folder.</li>
            <li><strong>Agents:</strong> Specialized AI personas. These live in the <code>agents/</code> folder.</li>
          </ul>
          <Callout>
            <strong>Tip:</strong> After adding new files to your Hub, always run <code>chain setup</code> so your AI tools can see the changes instantly.
          </Callout>
        </section>

        <section id="concepts">
          <h2>Core concepts</h2>
          <ul>
            <li><strong>One source of truth:</strong> All your AI knowledge lives in your Hub, not scattered across different apps.</li>
            <li><strong>Smart Templates:</strong> We provide a set of starter templates to get you going immediately.</li>
            <li><strong>Your Library:</strong> Create and maintain your own unique set of instructions and guides.</li>
            <li><strong>Universal Sync:</strong> Connect your Hub once, and every AI tool stays in sync automatically.</li>
          </ul>
        </section>

        <section id="continual-learning">
          <h2>Continual learning</h2>
          <p>
            Chain Hub can queue short learning events (success, failure, correction, or note) and roll them into a
            <strong>markdown draft</strong> you or an agent reviews before changing real skills.
          </p>
          <ul>
            <li><code>chain capture --event … --skill … --summary …</code> — append one JSON line to <code>learnings/queue/inbox.jsonl</code>.</li>
            <li><code>chain reflect</code> — group the inbox by skill slug, write <code>learnings/drafts/distill-*.md</code>, and archive the inbox. Use <code>--dry-run</code> to preview without moving files.</li>
            <li><strong>After reflect:</strong> inspect the draft, then copy vetted bullets into <code>learnings/shared/&lt;skill-slug&gt;/OVERLAY.md</code> or edit <code>skills/&lt;slug&gt;/SKILL.md</code> deliberately. Run <code>chain validate</code> before you consider the hub clean.</li>
          </ul>
          <p>
            The bundled <strong>hub-gardener</strong> workflow (under <code>workflows/</code> after <code>chain init</code>) describes a safe checklist:
            distill → read draft → validate → propose patches (hub-first; repo changes via PR only).
          </p>
        </section>

        <section id="commands">
          <h2>Command overview</h2>
          <div class="-mx-1 overflow-x-auto overscroll-x-contain px-1 max-[560px]:mx-0 max-[560px]:overflow-visible max-[560px]:px-0">
            <table class="w-full min-w-[560px] border-collapse max-[560px]:block max-[560px]:min-w-0 [&_tbody_td]:border-b [&_tbody_td]:border-border [&_tbody_td]:px-2 [&_tbody_td]:py-2.5 [&_tbody_td]:text-left [&_tbody_td]:align-top [&_tbody_td]:text-text-dim [&_td]:max-[560px]:block [&_td]:max-[560px]:w-full [&_td]:max-[560px]:border-none [&_td]:max-[560px]:p-0 [&_td]:max-[560px]:last:text-sm [&_td]:max-[560px]:last:leading-snug [&_td_code]:max-[560px]:break-words [&_th]:max-[560px]:hidden [&_thead]:max-[560px]:hidden [&_tr]:max-[560px]:mb-2.5 [&_tr]:max-[560px]:block [&_tr]:max-[560px]:rounded-[10px] [&_tr]:max-[560px]:border [&_tr]:max-[560px]:border-border-bright [&_tr]:max-[560px]:bg-surface-2 [&_tr]:max-[560px]:p-3 [&_tr]:max-[560px]:last:mb-0 [&_tr_td:first-child]:max-[560px]:mb-2 [&_tr_td:first-child]:max-[560px]:border-b [&_tr_td:first-child]:max-[560px]:border-border [&_tr_td:first-child]:max-[560px]:pb-2">
              <thead>
                <tr><th class="border-b border-border px-2 py-2.5 text-left align-top text-xs uppercase tracking-[0.08em] text-text-dim">Command</th><th class="border-b border-border px-2 py-2.5 text-left align-top text-xs uppercase tracking-[0.08em] text-text-dim">What it does</th></tr>
              </thead>
              <tbody>
                <tr><td><code>chain init</code></td><td>Sets up your central library with starter templates.</td></tr>
                <tr><td><code>chain setup</code></td><td>Connects your library to all your AI tools.</td></tr>
                <tr><td><code>chain status</code></td><td>Checks if all your connections are working correctly.</td></tr>
                <tr><td><code>chain list</code></td><td>Shows an overview of everything in your library.</td></tr>
                <tr><td><code>chain add &lt;slug&gt;</code></td><td>Installs expert knowledge shared by the community.</td></tr>
                <tr><td><code>chain update</code></td><td>Downloads the latest updates for your installed knowledge.</td></tr>
                <tr><td><code>chain new &lt;slug&gt;</code></td><td>Starts a new custom instruction from a template.</td></tr>
                <tr><td><code>chain validate</code></td><td>Checks for errors in your instructions.</td></tr>
                <tr><td><code>chain capture</code></td><td>Records one learning event into the hub inbox (for later <code>chain reflect</code>).</td></tr>
                <tr><td><code>chain reflect</code></td><td>Builds a draft markdown summary from the inbox and archives the queue (optional <code>--dry-run</code>).</td></tr>
                <tr><td><code>chain config get|set chain_home</code></td><td>Manages where your Hub is stored on your computer.</td></tr>
              </tbody>
            </table>
          </div>
          <p>
            Full detail lives in the CLI docs:
            <a href="https://github.com/martijnbokma/chain-hub/blob/main/cli/README.md" target="_blank" rel="noopener noreferrer">cli/README.md</a>.
          </p>
        </section>

        <section id="local-dev">
          <h2>Local development</h2>
          <p>
            If you work from a clone of the Chain Hub repo, run the CLI with Bun from <code>cli/</code> without publishing to npm. See
            <a href="https://github.com/martijnbokma/chain-hub/blob/main/cli/README.md" target="_blank" rel="noopener noreferrer">cli/README.md</a>
            for the full contributor workflow.
          </p>
          <TerminalBlock code={`$ cd cli\n$ bun install\n$ bun run dev -- --help`} />
        </section>

        <section id="troubleshooting">
          <h2>Troubleshooting</h2>
          <p><strong><code>chain</code> runs the wrong binary?</strong> Check aliases first.</p>
          <TerminalBlock code={`$ which -a chain\n$ type chain`} />
          <p>
            If you see an old alias (for example <code>bun run …/Code/chain/cli/chain.ts</code> after renaming or moving the monorepo),
            update <code>CHAIN_HUB_REPO</code> / the alias target to your current clone (see <code>cli/README.md</code>), remove the stale line from your shell profile,
            then run <code>unalias chain</code> and open a new terminal.
          </p>

          <p><strong>Skill doesn't appear in your editor?</strong></p>
          <p>
            Check symlink health with <code>chain status</code>, then recreate links with <code>chain setup</code>.
            Reopen the editor afterward — some editors cache skill paths at startup.
          </p>
          <TerminalBlock code={`$ chain status\n$ chain setup`} />

          <p><strong><code>chain validate</code> reports a nested or unknown layout?</strong></p>
          <p>
            Skills must use a flat layout — only <code>skills/&lt;slug&gt;/SKILL.md</code> is valid.
            Nested category folders are not supported. Move or flatten the directory.
          </p>
          <pre class="overflow-x-auto rounded-lg border border-border bg-surface-2 p-4 text-[12px] leading-[1.7] text-text-dim">✓  skills/debug/SKILL.md
✗  skills/utilities/debug/SKILL.md   ← nested, not supported</pre>

          <p><strong>Skills disappeared after Syncthing or Dropbox sync?</strong></p>
          <p>
            Syncing a hub without <code>.git/</code> can propagate deletions from a partial replica.
            Use a single writer for the hub, or exclude <code>skills/</code> from bidirectional sync.
            Restore from backup or re-run <code>chain add</code> for registry sources.
          </p>
        </section>
      </article>
      </div>
    </div>
  </main>

  <Footer layoutClass="layout-wrap-docs" compact />
</div>

<script is:inline>
  const nav = document.getElementById('nav');
  function syncNavDocs() {
    if (!nav) return;
    if (window.scrollY > 36) nav.setAttribute('data-scrolled', 'true');
    else nav.removeAttribute('data-scrolled');
  }
  syncNavDocs();
  window.addEventListener('scroll', syncNavDocs, { passive: true });

  const navMenu = document.getElementById('nav-menu');
  if (navMenu) {
    navMenu.querySelectorAll('ul a').forEach(function (a) {
      a.addEventListener('click', function () { navMenu.removeAttribute('open'); });
    });
  }

  const docsTocMobile = document.getElementById('docs-toc-mobile');
  if (docsTocMobile) {
    docsTocMobile.querySelectorAll('a[href^="#"]').forEach(function (a) {
      a.addEventListener('click', function () {
        docsTocMobile.removeAttribute('open');
      });
    });
  }
</script>
</body>
</html>
