---
import BrandLogo from "../BrandLogo.astro";

interface Props {
  layoutClass?: string;
  compact?: boolean;
}
const { layoutClass = "layout-wrap", compact = false } = Astro.props;
---
<!-- ── FOOTER ─────────────────────────────────────────────────────── -->
<footer class="border-t border-border py-9 sm:py-11">
  <div class:list={[layoutClass, "flex flex-col gap-6 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between sm:gap-4"]}>
    <div class="flex min-w-0 items-center gap-2 font-display text-base font-bold tracking-[-0.055em] text-text-dim sm:text-lg">
      <BrandLogo class="size-8 shrink-0 sm:size-9" />
      Chain Hub
    </div>
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <div class="min-w-0 text-[11px] leading-relaxed text-text-faint">
        <a class="inline-flex items-center align-middle leading-none text-text-dim transition-colors hover:text-accent" href="https://github.com/martijnbokman/chain-hub" target="_blank" rel="noopener noreferrer" aria-label="Chain Hub on GitHub">
          <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" clip-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482C19.138 20.197 22 16.425 22 12.017 22 6.484 17.522 2 12 2z"/></svg>
        </a>
        {!compact && (
          <>
            ·
            Made with <svg class="-mt-0.5 mx-0.5 inline size-3 text-accent align-middle" viewBox="0 0 24 24" fill="currentColor" role="img" aria-label="love"><path d="M12 21s-7.2-4.5-9.6-8.4C.4 9.4 1.3 5.5 4.5 4.1 7 3 9.6 3.8 12 6.3 14.4 3.8 17 3 19.5 4.1c3.2 1.4 4.1 5.3 2.1 8.5C19.2 16.5 12 21 12 21Z"/></svg> by <a href="https://martijnbokma.nl" class="text-text-dim no-underline transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">Martijn Bokma</a>.
          </>
        )}
      </div>
      {!compact && (
        <a class="inline-flex min-h-10 items-center justify-center self-start rounded-full border border-[rgba(139,124,255,0.35)] bg-[rgba(139,124,255,0.08)] px-4 py-2 text-[11px] font-semibold text-text no-underline transition-[border-color,color,background] hover:border-[rgba(139,124,255,0.65)] hover:bg-[rgba(139,124,255,0.14)] hover:text-accent sm:self-auto" href="https://www.paypal.com/paypalme/martijnbokma" target="_blank" rel="noopener noreferrer">Donate</a>
      )}
    </div>
  </div>
</footer>
