---
---
<!-- ── TEXT FIRST ────────────────────────────────────────────────── -->
<section class="py-32 max-md:py-20 bg-surface" id="text-first">
  <div class="layout-wrap">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-start">
      <div class="fi opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Open format</div>
        <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">Skills are<br><em class="not-italic text-accent">just Markdown.</em></h2>
        <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim mb-8">
          A skill is a Markdown file with a small YAML frontmatter header. Your editor reads it, your AI follows it. No lock-in, no proprietary format.
        </p>
        <ul class="space-y-4 list-none">
          <li class="flex items-center gap-3 text-xs text-text-dim">
            <span class="size-1.5 rounded-full bg-accent"></span>
            Version-controlled with git.
          </li>
          <li class="flex items-center gap-3 text-xs text-text-dim">
            <span class="size-1.5 rounded-full bg-accent"></span>
            Readable and editable by humans.
          </li>
          <li class="flex items-center gap-3 text-xs text-text-dim">
            <span class="size-1.5 rounded-full bg-accent"></span>
            Works across every supported editor.
          </li>
        </ul>
      </div>

      <div class="fi delay-200 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100 flex flex-col gap-4">
        <!-- Main code panel -->
        <div class="bg-surface-2 border border-border rounded-xl p-1 overflow-hidden shadow-2xl">
          <div class="bg-surface border-b border-border px-4 py-2 flex items-center gap-2">
            <div class="size-2.5 rounded-full bg-border"></div>
            <div class="text-[10px] text-text-faint font-mono">debug/SKILL.md</div>
          </div>
          <div class="p-6 font-mono text-[12px] leading-relaxed text-text-dim">
            <span class="text-text-dim">---</span><br/>
            <span class="text-text-dim"><span class="text-text">name</span>: debug</span><br/>
            <span class="text-text-dim"><span class="text-text">description</span>: Systematic debugging with root-cause analysis.</span><br/>
            <span class="text-text-dim"><span class="text-text">version</span>: "1.0"</span><br/>
            <span class="text-text-dim">---</span><br/>
            <br/>
            <span class="text-accent">## When to use</span><br/>
            <span class="text-text-dim">When you hit an error, unexpected behavior, or need</span><br/>
            <span class="text-text-dim">to trace a bug to its root cause.</span><br/>
            <br/>
            <span class="text-accent">## Steps</span><br/>
            <span class="text-text-dim">1. Reproduce the issue</span><br/>
            <span class="text-text-dim">2. Isolate the failing component</span><br/>
            <span class="text-text-dim">3. Identify root cause</span><br/>
            <span class="text-text-dim">4. Apply minimal fix</span>
          </div>
        </div>

        <!-- Note panel -->
        <div class="border-l-2 border-accent bg-surface-2 rounded-r-xl px-5 py-4 text-[11px] leading-[1.65] text-text-dim">
          This file is now active in Cursor, Claude Code, Windsurf, and every other editor you've set up — simultaneously.
        </div>
      </div>
    </div>
  </div>
</section>
