---
---
<!-- ── ARCHITECTURE ───────────────────────────────────────────────── -->
<section class="py-32 max-md:py-20 bg-bg" id="architecture">
  <div class="layout-wrap">
    <div class="fi mb-16 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100 text-center flex flex-col items-center">
      <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">How it flows</div>
      <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">One file.<br><em class="not-italic text-accent">Every editor.</em></h2>
      <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim">
        <code class="text-text text-xs">chain setup</code> creates symlinks from your hub to each editor's config directory. Edit once in <code class="text-text text-xs">~/chain-hub</code> — all editors pick it up instantly.
      </p>
    </div>

    <div class="fi delay-100 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
      <div class="rounded-2xl border border-border bg-surface-2 p-8 sm:p-12">
        <div class="flex flex-col items-center gap-6">

          <!-- Source box -->
          <div class="w-full max-w-[480px] rounded-lg border border-accent bg-surface px-6 py-4 text-center shadow-[0_0_24px_rgba(139,124,255,0.15)]">
            <div class="font-mono text-[11px] text-text-dim mb-1">source</div>
            <div class="font-mono text-sm text-accent tracking-tight">~/chain-hub/skills/debug/SKILL.md</div>
          </div>

          <!-- Arrow -->
          <div class="flex flex-col items-center gap-1">
            <div class="text-[11px] text-text-dim font-mono tracking-[0.05em]">chain setup ↓</div>
            <div class="h-8 w-px bg-gradient-to-b from-accent/60 to-border"></div>
          </div>

          <!-- Destination boxes -->
          <div class="w-full">
            <div class="flex flex-wrap justify-center gap-4">
              <div class="rounded-lg border border-border bg-surface px-5 py-3 text-center">
                <div class="font-mono text-xs text-text-dim">~/.claude/</div>
              </div>
              <div class="rounded-lg border border-border bg-surface px-5 py-3 text-center">
                <div class="font-mono text-xs text-text-dim">~/.cursor/</div>
              </div>
              <div class="rounded-lg border border-border bg-surface px-5 py-3 text-center">
                <div class="font-mono text-xs text-text-dim">~/.codeium/windsurf/</div>
              </div>
            </div>
            <div class="mt-4 text-center text-[11px] text-text-dim font-mono">+ 6 more</div>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>
