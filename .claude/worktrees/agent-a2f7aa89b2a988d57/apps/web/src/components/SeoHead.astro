---
interface Props {
  title: string;
  description: string;
  /** Site path starting with `/`, e.g. `/` or `/docs/` */
  path: string;
  ogType?: 'website' | 'article';
  /** Single JSON-LD object or list of nodes merged into one `@graph` */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
  /** Short label for social previews (accessibility + some crawlers) */
  ogImageAlt?: string;
}

const {
  title,
  description,
  path,
  ogType = 'website',
  jsonLd,
  ogImageAlt = 'Chain Hub — One Chain Hub to rule them all',
} = Astro.props;

const siteUrl = Astro.site ?? new URL('https://www.chainhub.one/');
const normalizedPath = path.startsWith('/') ? path : `/${path}`;
const canonical = new URL(normalizedPath, siteUrl).href;
const ogImageUrl = new URL('/og.png', siteUrl).href;

const graphNodes: Record<string, unknown>[] = Array.isArray(jsonLd)
  ? jsonLd
  : jsonLd
    ? [jsonLd]
    : [];

const jsonLdScript =
  graphNodes.length > 0
    ? JSON.stringify({
        '@context': 'https://schema.org',
        '@graph': graphNodes,
      })
    : null;
---
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>{title}</title>
<meta name="description" content={description}>
<meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
<meta name="theme-color" content="#070912">
<link rel="canonical" href={canonical}>
<link rel="icon" href="/favicon.svg" type="image/svg+xml">
<link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

<meta property="og:url" content={canonical}>
<meta property="og:title" content={title}>
<meta property="og:description" content={description}>
<meta property="og:type" content={ogType}>
<meta property="og:site_name" content="Chain Hub">
<meta property="og:locale" content="en_US">
<meta property="og:image" content={ogImageUrl}>
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">
<meta property="og:image:type" content="image/png">
<meta property="og:image:alt" content={ogImageAlt}>

<meta name="twitter:card" content="summary_large_image">
<meta name="twitter:title" content={title}>
<meta name="twitter:description" content={description}>
<meta name="twitter:image" content={ogImageUrl}>

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=JetBrains+Mono:wght@300;400;500;600&display=swap"
  rel="stylesheet"
>
{jsonLdScript && (
  <script type="application/ld+json" set:html={jsonLdScript} />
)}
