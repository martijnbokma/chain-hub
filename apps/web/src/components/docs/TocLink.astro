---
interface Props {
  href: string;
  label: string;
}
const { href, label } = Astro.props;
---
<li class="m-0">
  <a
    href={href}
    class="block rounded-md px-2 py-1.5 text-[13px] text-text-dim no-underline transition-colors hover:bg-[rgba(139,124,255,0.1)] hover:text-text"
    >{label}</a
  >
</li>
