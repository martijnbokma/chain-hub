---
import { Icon } from 'astro-icon/components';
import TocLink from './TocLink.astro';

interface TocItem {
  href: string;
  label: string;
}

interface Props {
  tocItems: readonly TocItem[];
}

const { tocItems } = Astro.props;
---
<div class="relative isolate min-h-dvh">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_55%_42%_at_72%_12%,rgba(139,124,255,0.11)_0%,transparent_62%),radial-gradient(ellipse_40%_36%_at_12%_28%,rgba(72,176,255,0.06)_0%,transparent_58%)]" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute inset-0 bg-[length:64px_64px] [background-image:linear-gradient(rgba(239,242,255,0.06)_1px,transparent_1px),linear-gradient(90deg,rgba(239,242,255,0.06)_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_85%_55%_at_50%_0%,black,transparent_72%)]"
    aria-hidden="true"
  ></div>

  <main class="layout-wrap-docs relative z-10">
    <section class="border-b border-border pb-10 pt-[calc(88px+env(safe-area-inset-top,0px))] max-[680px]:pb-8 max-[680px]:pt-[calc(76px+env(safe-area-inset-top,0px))]">
      <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Documentation</div>
      <h1 class="mb-5 font-display text-[clamp(34px,5.5vw,54px)] font-bold leading-[1.02] tracking-[-0.06em]">Docs</h1>
      <p class="max-w-[70ch] text-sm leading-[1.75] text-text-dim">
        Lightweight reference for Chain Hub — installation, the
        <code class="rounded-[5px] border border-accent/25 bg-accent/10 px-1.5 py-px text-[12px] text-code-inline">CHAIN_HOME</code> model, and core CLI commands.
      </p>
    </section>

    <div class="grid min-w-0 grid-cols-1 gap-6 pb-16 pt-8 max-md:gap-5 max-md:pb-[max(48px,env(safe-area-inset-bottom,0px))] max-md:pt-6 md:grid-cols-[248px_minmax(0,1fr)] md:gap-8 md:pb-20">
      <aside
        class="sticky top-[calc(72px+20px+env(safe-area-inset-top,0px))] hidden min-w-0 self-start rounded-[10px] border border-border-bright bg-surface p-4 shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] md:block"
        aria-label="Table of contents"
      >
        <div class="mb-3 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Contents</div>
        <ul class="m-0 flex list-none flex-col gap-1.5">
          {tocItems.map((item) => <TocLink href={item.href} label={item.label} />)}
        </ul>
      </aside>
      <div class="min-w-0">
        <details
          id="docs-toc-mobile"
          class="group/toc sticky top-[calc(68px+env(safe-area-inset-top,0px))] z-[90] mb-5 rounded-[10px] border border-border-bright bg-[rgba(12,15,26,0.92)] shadow-[inset_0_1px_0_rgba(255,255,255,0.04),0_8px_32px_rgba(0,0,0,0.35)] backdrop-blur-[14px] md:hidden"
        >
          <summary
            class="flex cursor-pointer list-none items-center justify-between gap-3 px-3.5 py-3 text-[11px] font-medium uppercase tracking-[0.14em] text-text-dim transition-colors hover:text-text [&::-webkit-details-marker]:hidden"
          >
            <span class="before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Contents</span>
            <Icon name="lucide:chevron-down" class="size-3.5 shrink-0 text-text-dim transition group-open/toc:rotate-180" aria-hidden="true" />
          </summary>
          <nav class="border-t border-border px-2 pb-2 pt-1" aria-label="Page sections">
            <ul class="m-0 max-h-[min(55vh,380px)] list-none space-y-0.5 overflow-y-auto overscroll-y-contain py-1">
              {tocItems.map((item) => (
                <li class="m-0">
                  <a
                    href={item.href}
                    class="block rounded-md px-2.5 py-2 text-[13px] text-text-dim no-underline transition-colors hover:bg-[rgba(139,124,255,0.1)] hover:text-text"
                  >
                    {item.label}
                  </a>
                </li>
              ))}
            </ul>
          </nav>
        </details>
        <article class="ch-docs-prose min-w-0 [&_h2]:mb-3 [&_h2]:mt-0 [&_h2]:font-display [&_h2]:text-[clamp(22px,3.2vw,28px)] [&_h2]:font-bold [&_h2]:leading-[1.08] [&_h2]:tracking-[-0.04em] [&_li]:mb-1.5 [&_p]:mb-2.5 [&_p]:text-text-dim [&_section]:mb-5 [&_section]:scroll-mt-[calc(56px+24px+env(safe-area-inset-top,0px))] [&_section]:rounded-[10px] [&_section]:border [&_section]:border-border-bright [&_section]:bg-surface [&_section]:p-6 [&_section]:shadow-[inset_0_1px_0_rgba(255,255,255,0.035)] max-[680px]:[&_section]:mb-4 max-[680px]:[&_section]:p-4 [&_strong]:font-semibold [&_strong]:text-text [&_ul]:ml-[18px] [&_ul]:text-text-dim">
          <slot />
        </article>
      </div>
    </div>
  </main>

  <slot name="footer" />
</div>
