---
import { formatInstallCommentLine, getMarketingSymlinkRows } from 'chain-setup-display-paths';

const installAdapterCommentLines = getMarketingSymlinkRows().map(formatInstallCommentLine);
---
<!-- ── INSTALL ────────────────────────────────────────────────────── -->
<section class="border-y border-border py-32 max-md:py-20" id="install">
  <div class="layout-wrap">
    <div class="grid min-w-0 grid-cols-1 items-start gap-12 md:grid-cols-2 md:gap-20 lg:gap-x-20">
      <div class="fi min-w-0 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Quick start</div>
        <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">Simple setup,<br><em class="not-italic text-accent">infinite power.</em></h2>
        <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim">
          Set up your hub, connect your apps, and start building your AI library. 
          Chain Hub takes care of the technical heavy lifting so you can focus on your knowledge.
        </p>
        <div class="mt-9 flex flex-col [&>div:last-child]:border-b-0">
          <div class="flex gap-3.5 border-b border-border py-[18px]">
            <div class="shrink-0 text-accent" aria-hidden="true">↳</div>
            <div class="text-xs leading-[1.65] text-text-dim [&_code]:text-[rgba(139,124,255,0.62)] [&_strong]:font-normal [&_strong]:text-text">
              <strong>Smart Sync</strong> — If anything gets disconnected, one command fixes and restores everything automatically.
            </div>
          </div>
          <div class="flex gap-3.5 border-b border-border py-[18px]">
            <div class="shrink-0 text-accent" aria-hidden="true">↳</div>
            <div class="text-xs leading-[1.65] text-text-dim [&_strong]:font-normal [&_strong]:text-text">
              <strong>Lightweight</strong> — Fast, efficient, and runs directly on your computer without slowing you down.
            </div>
          </div>
          <div class="flex gap-3.5 border-b border-border py-[18px]">
            <div class="shrink-0 text-accent" aria-hidden="true">↳</div>
            <div class="text-xs leading-[1.65] text-text-dim [&_code]:text-[rgba(139,124,255,0.62)] [&_strong]:font-normal [&_strong]:text-text">
              <strong>Quality Control</strong> — Built-in checks ensure your instructions are always clear and ready for your AI.
            </div>
          </div>
          <div class="flex gap-3.5 border-b border-border py-[18px]">
            <div class="shrink-0 text-accent" aria-hidden="true">↳</div>
            <div class="text-xs leading-[1.65] text-text-dim [&_code]:text-[rgba(139,124,255,0.62)] [&_strong]:font-normal [&_strong]:text-text">
              <strong>Community Ready</strong> — Easily add expert knowledge shared by others with a single command.
            </div>
          </div>
        </div>
      </div>

      <div class="fi min-w-0 overflow-hidden rounded-md border border-border-bright bg-surface delay-100 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="flex min-w-0 items-center justify-between gap-3 border-b border-border bg-surface-2 px-4 py-3 sm:px-[18px] sm:py-[11px]">
          <span class="min-w-0 truncate text-[10px] uppercase tracking-[0.07em] text-text-dim">bash</span>
          <button class="inline-flex min-h-9 min-w-9 shrink-0 cursor-pointer items-center justify-center rounded-md border-none bg-transparent font-mono text-[10px] tracking-[0.05em] text-text-faint transition-colors hover:text-accent" id="copy-btn" type="button">copy</button>
        </div>
        <div class="overflow-x-auto overscroll-x-contain px-4 py-5 text-[11px] leading-[1.95] sm:px-5 sm:py-6 sm:text-[12.5px] sm:leading-[2]">
          <span class="block text-text-faint"># 0. Overview: https://www.chainhub.one/</span>
          <br>
          <span class="block text-text-faint"># 1. Install Chain Hub globally</span>
          <div class="flex gap-2">
            <span class="shrink-0 text-accent">$</span>
            <span class="text-text">npm install -g chain-hub</span>
          </div>
          <br>
          <span class="block text-text-faint"># 2. Initialize your hub</span>
          <div class="flex gap-2">
            <span class="shrink-0 text-accent">$</span>
            <span class="text-text">chain init</span>
          </div>
          <br>
          <span class="block text-text-faint"># 3. Sync all your AI editors in one shot</span>
          <div class="flex gap-2">
            <span class="shrink-0 text-accent">$</span>
            <span class="text-text">chain setup</span>
          </div>
          <br>
          <span class="block text-text-faint"># Optional: persist a custom hub location</span>
          <div class="flex gap-2">
            <span class="shrink-0 text-accent">$</span>
            <span class="text-text">chain config set chain_home ~/my-chain-home</span>
          </div>
          <br>
          {installAdapterCommentLines.map((line) => (
            <span class="block text-green">{line}</span>
          ))}
          <br>
          <span class="block text-accent"># Example: detected IDEs linked. Then extend skills/, workflows/, rules/.</span>
        </div>
      </div>

    </div>
  </div>
</section>
