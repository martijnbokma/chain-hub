---
import BrandLogo from "../BrandLogo.astro";
import { Icon } from "astro-icon/components";

interface Props {
  layoutClass?: string;
  compact?: boolean;
}
const { layoutClass = "layout-wrap", compact = false } = Astro.props;
---
<!-- ── FOOTER ─────────────────────────────────────────────────────── -->
<footer class="border-t border-border py-9 sm:py-11">
  <div class:list={[layoutClass, "flex flex-col gap-6 sm:flex-row sm:flex-wrap sm:items-center sm:justify-between sm:gap-4"]}>
    <div class="flex min-w-0 items-center gap-2 font-display text-base font-bold tracking-[-0.055em] text-text-dim sm:text-lg">
      <BrandLogo class="size-8 shrink-0 sm:size-9" />
      Chain Hub
    </div>
    <div class="flex min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center">
      <div class="min-w-0 text-[11px] leading-relaxed text-text-faint">
        <a class="inline-flex items-center align-middle leading-none text-text-dim transition-colors hover:text-accent" href="https://github.com/martijnbokman/chain-hub" target="_blank" rel="noopener noreferrer" aria-label="Chain Hub on GitHub">
          <Icon name="lucide:github" class="size-4" aria-hidden="true" />
        </a>
        {!compact && (
          <>
            ·
            Made with <Icon name="lucide:heart" class="-mt-0.5 mx-0.5 inline size-3 text-accent align-middle" aria-label="love" /> by <a href="https://martijnbokma.nl" class="text-text-dim no-underline transition-colors hover:text-accent" target="_blank" rel="noopener noreferrer">Martijn Bokma</a>.
          </>
        )}
      </div>
      {!compact && (
        <a class="inline-flex min-h-10 items-center justify-center self-start rounded-full border border-[rgba(139,124,255,0.35)] bg-[rgba(139,124,255,0.08)] px-4 py-2 text-[11px] font-semibold text-text no-underline transition-[border-color,color,background] hover:border-[rgba(139,124,255,0.65)] hover:bg-[rgba(139,124,255,0.14)] hover:text-accent sm:self-auto" href="https://www.paypal.com/paypalme/martijnbokma" target="_blank" rel="noopener noreferrer">Donate</a>
      )}
    </div>
  </div>
</footer>
