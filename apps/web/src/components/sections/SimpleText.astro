<!-- ── TEXT FIRST ────────────────────────────────────────────────── -->
<section class="py-32 max-md:py-20 bg-surface" id="text-first">
  <div class="layout-wrap">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-16 items-center">
      <div class="fi opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Simplicity</div>
        <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">Knowledge is<br><em class="not-italic text-accent">just simple text.</em></h2>
        <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim mb-8">
          You don't need to write code to make your AI smarter. Your "Hub" is simply a collection of Markdown files—the same format you use in apps like Notion, Obsidian, or even simple notes.
        </p>
        <ul class="space-y-4 list-none">
          <li class="flex items-center gap-3 text-xs text-text-dim">
            <span class="size-1.5 rounded-full bg-accent"></span>
            No complex databases or setup.
          </li>
          <li class="flex items-center gap-3 text-xs text-text-dim">
            <span class="size-1.5 rounded-full bg-accent"></span>
            Easily readable and editable by humans.
          </li>
          <li class="flex items-center gap-3 text-xs text-text-dim">
            <span class="size-1.5 rounded-full bg-accent"></span>
            Works with any text editor you already love.
          </li>
        </ul>
      </div>

      <div class="fi delay-200 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100 bg-surface-2 border border-border rounded-xl p-1 overflow-hidden shadow-2xl">
        <div class="bg-surface border-b border-border px-4 py-2 flex items-center gap-2">
          <div class="size-2.5 rounded-full bg-border"></div>
          <div class="text-[10px] text-text-faint font-mono">brand-voice.md</div>
        </div>
        <div class="p-6 font-mono text-[12px] leading-relaxed text-text-dim">
          <span class="text-accent"># Brand Voice</span><br/>
          <br/>
          <span class="text-text-faint">## Core Values</span><br/>
          - Helpful and friendly<br/>
          - Professional but not stiff<br/>
          - Clear and concise<br/>
          <br/>
          <span class="text-text-faint">## Writing Style</span><br/>
          - Use active voice<br/>
          - Avoid corporate jargon<br/>
          - Keep sentences short<br/>
          <br/>
          <span class="text-green-400/70">/* This simple file now controls <br/>
          all your AI assistants. */</span>
        </div>
      </div>
    </div>
  </div>
</section>
