<!-- ── USE CASES ────────────────────────────────────────────────── -->
<section class="py-32 max-md:py-20 bg-surface-2" id="use-cases">
  <div class="layout-wrap">
    <div class="fi mb-16 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
      <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Versatility</div>
      <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">More than just<br><em class="not-italic text-accent">for developers.</em></h2>
      <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim">
        Chain Hub is for anyone who wants their AI to be smarter and more consistent. 
        Whether you're crafting copy, managing projects, or building apps, your knowledge stays with you.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="fi flex flex-col p-8 border border-border bg-surface opacity-0 translate-y-[18px] transition-[opacity,transform] delay-100 duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="text-2xl mb-4" aria-hidden="true">✍️</div>
        <h3 class="text-lg font-bold mb-3">Content & Marketing</h3>
        <p class="text-sm text-text-dim leading-[1.6]">
          Store your <strong class="text-text">Brand Voice</strong>, style guides, and target audience personas once. 
          Use them instantly in Claude, ChatGPT, Gemini, or your coding assistant (Cursor, Antigravity, Windsurf, …) without repeating yourself.
        </p>
      </div>

      <div class="fi flex flex-col p-8 border border-border bg-surface opacity-0 translate-y-[18px] transition-[opacity,transform] delay-200 duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="text-2xl mb-4" aria-hidden="true">📋</div>
        <h3 class="text-lg font-bold mb-3">Project Management</h3>
        <p class="text-sm text-text-dim leading-[1.6]">
          Keep <strong class="text-text">Project Context</strong> and technical specs in one central place. 
          Your AI assistants will always have the latest requirements, no matter where you're working.
        </p>
      </div>

      <div class="fi flex flex-col p-8 border border-border bg-surface opacity-0 translate-y-[18px] transition-[opacity,transform] delay-300 duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="text-2xl mb-4" aria-hidden="true">🏢</div>
        <h3 class="text-lg font-bold mb-3">Expert Guidelines</h3>
        <p class="text-sm text-text-dim leading-[1.6]">
          Define <strong class="text-text">Standard Procedures</strong> for legal reviews, code audits, or data analysis. 
          Ensure every AI interaction follows your organization's highest standards.
        </p>
      </div>
    </div>
  </div>
</section>
