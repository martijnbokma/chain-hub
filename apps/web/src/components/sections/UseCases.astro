<!-- ── USE CASES ────────────────────────────────────────────────── -->
<section class="py-32 max-md:py-20 bg-surface-2" id="use-cases">
  <div class="layout-wrap">
    <div class="fi mb-16 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
      <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-kicker before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Built for developers</div>
      <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">Built for<br><em class="not-italic text-accent">developers.</em></h2>
      <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim">
        Whether you switch editors daily or run a team with shared standards — Chain Hub keeps your AI context consistent.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="fi flex flex-col p-8 border border-border bg-surface opacity-0 translate-y-[18px] transition-[opacity,transform] delay-100 duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <h3 class="text-lg font-bold mb-3">Cursor at work, Claude Code at home</h3>
        <p class="text-sm text-text-dim leading-[1.6]">
          One hub, both synced. Your skills, rules, and agents follow you across machines and editors without any manual copying.
        </p>
      </div>

      <div class="fi flex flex-col p-8 border border-border bg-surface opacity-0 translate-y-[18px] transition-[opacity,transform] delay-200 duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <h3 class="text-lg font-bold mb-3">Shared code style for your team</h3>
        <p class="text-sm text-text-dim leading-[1.6]">
          Put your conventions in <code class="text-text bg-surface-2 px-1 rounded text-xs">global.md</code> and run <code class="text-text bg-surface-2 px-1 rounded text-xs">chain setup</code>. Every team member's AI editor follows the same rules.
        </p>
      </div>

      <div class="fi flex flex-col p-8 border border-border bg-surface opacity-0 translate-y-[18px] transition-[opacity,transform] delay-200 duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <h3 class="text-lg font-bold mb-3">Switch editors per project</h3>
        <p class="text-sm text-text-dim leading-[1.6]">
          <code class="text-text bg-surface-2 px-1 rounded text-xs">CHAIN_HOME</code> is editor-agnostic. Move to a new editor, run <code class="text-text bg-surface-2 px-1 rounded text-xs">chain setup</code>, and your full skill library is available instantly.
        </p>
      </div>

      <div class="fi flex flex-col p-8 border border-border bg-surface opacity-0 translate-y-[18px] transition-[opacity,transform] delay-300 duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <h3 class="text-lg font-bold mb-3">20 prompts scattered everywhere</h3>
        <p class="text-sm text-text-dim leading-[1.6]">
          Run <code class="text-text bg-surface-2 px-1 rounded text-xs">migrate-to-skills</code> to consolidate your existing prompts into versioned, reusable skills in your hub.
        </p>
      </div>
    </div>
  </div>
</section>
