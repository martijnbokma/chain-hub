<div class="mb-8 max-w-xl">
  <label for="registry-search" class="sr-only">Search skills</label>
  <input
    id="registry-search"
    type="search"
    name="q"
    autocomplete="off"
    placeholder="Search by name or description…"
    class="w-full rounded-xl border border-border bg-surface px-4 py-3 text-[14px] text-text shadow-[inset_0_1px_0_rgba(255,255,255,0.04)] placeholder:text-text-faint focus:border-[rgba(139,124,255,0.45)] focus:outline-none focus:ring-2 focus:ring-[rgba(139,124,255,0.25)]"
  />
  <p id="registry-count" class="mt-2 text-[12px] text-text-faint" aria-live="polite"></p>
</div>
