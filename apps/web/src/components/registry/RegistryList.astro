---
interface Skill {
  slug: string;
  description: string;
  version: string;
  source: string;
  path: string;
}

interface Props {
  skills: Skill[];
}

const { skills } = Astro.props;
---

<ul id="registry-list" class="m-0 grid list-none gap-4 p-0 sm:grid-cols-2">
  {
    skills.map((skill) => (
      <li
        class="registry-card rounded-xl border border-border bg-gradient-to-b from-surface to-surface-2 p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.05)]"
        data-slug={skill.slug}
        data-desc={skill.description}
      >
        <div class="flex flex-wrap items-baseline justify-between gap-2">
          <h2 class="m-0 font-display text-base font-semibold tracking-[-0.03em] text-text">
            <code class="text-accent">{skill.slug}</code>
          </h2>
          <span class="text-[11px] uppercase tracking-[0.08em] text-text-faint">v{skill.version}</span>
        </div>
        <p class="mt-3 mb-4 text-[13px] leading-relaxed text-text-dim">{skill.description}</p>
        <div class="flex flex-wrap gap-3 text-[12px]">
          <code class="rounded-md bg-[rgba(0,0,0,0.25)] px-2 py-1 text-text-dim">chain add {skill.slug}</code>
          <a
            class="text-accent no-underline hover:underline"
            href={`https://github.com/martijnbokman/chain-hub/tree/main/${skill.path}`}
          >
            Source
          </a>
        </div>
      </li>
    ))
  }
</ul>

<p id="registry-empty" class="hidden text-text-dim" role="status">No skills match your search.</p>
