---
export const prerender = true;
import { existsSync, readFileSync } from 'node:fs';
import { join, resolve } from 'node:path';
import { parse } from 'yaml';

function resolveRepoRoot(): string {
  let dir = resolve(process.cwd());
  for (let i = 0; i < 8; i++) {
    if (existsSync(join(dir, 'registry', 'index.yaml'))) return dir;
    const parent = resolve(dir, '..');
    if (parent === dir) break;
    dir = parent;
  }
  throw new Error('registry/index.yaml not found; expected a monorepo root containing registry/');
}
import SiteHeader from '../../components/SiteHeader.astro';
import Footer from '../../components/sections/Footer.astro';
import SeoHead from '../../components/SeoHead.astro';
import RegistryHero from '../../components/registry/RegistryHero.astro';
import RegistrySearch from '../../components/registry/RegistrySearch.astro';
import RegistryList from '../../components/registry/RegistryList.astro';

const base = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.origin ?? 'https://www.chainhub.one';

interface IndexSkill {
  slug: string;
  description: string;
  version: string;
  source: string;
  path: string;
}

interface RegistryFile {
  skills: IndexSkill[];
}

const repoRoot = resolveRepoRoot();
const raw = readFileSync(join(repoRoot, 'registry', 'index.yaml'), 'utf8');
const registry = parse(raw) as RegistryFile;
const skills = registry.skills.slice().sort((a, b) => a.slug.localeCompare(b.slug));

const pageTitle = 'Chain Hub skill registry | Browse & install';
const pageDescription =
  'Browse indexed Chain Hub skills: descriptions, versions, and install commands (`chain add <slug>`). Search the public registry.';

const registryJsonLd: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
      { '@type': 'ListItem', position: 2, name: 'Registry', item: `${siteOrigin}/registry/` },
    ],
  },
  {
    '@type': 'WebPage',
    name: pageTitle,
    description: pageDescription,
    url: `${siteOrigin}/registry/`,
    inLanguage: 'en',
    isPartOf: { '@type': 'WebSite', name: 'Chain Hub', url: `${siteOrigin}/` },
  },
];

const headerNavItems = [
  { href: `${base}docs/`, label: 'Docs' },
  { href: `${base}registry/`, label: 'Registry' },
  { href: `${base}#install`, label: 'Get started', cta: true },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <SeoHead
    title={pageTitle}
    description={pageDescription}
    path="/registry/"
    ogType="website"
    jsonLd={registryJsonLd}
    ogImageAlt="Chain Hub skill registry"
  />
</head>
<body class="ch-site min-w-0 overflow-x-hidden bg-bg pb-[env(safe-area-inset-bottom,0px)] font-mono text-[13px] leading-[1.65] text-text antialiased [text-size-adjust:100%]">
  <SiteHeader items={headerNavItems} mobilePrefix={[{ href: base, label: 'Home' }]} />

  <div class="relative isolate min-h-dvh">
    <div
      class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_55%_42%_at_72%_12%,rgba(139,124,255,0.11)_0%,transparent_62%),radial-gradient(ellipse_40%_36%_at_12%_28%,rgba(72,176,255,0.06)_0%,transparent_58%)]"
      aria-hidden="true"
    ></div>

    <main class="layout-wrap relative pt-[calc(88px+env(safe-area-inset-top,0px))] pb-16 min-[681px]:pt-[calc(104px+env(safe-area-inset-top,0px))]">
      <RegistryHero />
      <RegistrySearch />
      <RegistryList skills={skills} />
    </main>

    <Footer />
  </div>

  <script is:inline>
    (function () {
      const list = document.getElementById('registry-list');
      const input = document.getElementById('registry-search');
      const countEl = document.getElementById('registry-count');
      const emptyEl = document.getElementById('registry-empty');
      if (!list || !input || !countEl || !emptyEl) return;

      const cards = Array.from(list.querySelectorAll('.registry-card'));

      function score(slug, desc, q) {
        if (!q) return 1;
        const s = slug.toLowerCase();
        const d = desc.toLowerCase();
        if (s === q) return 1e6;
        const segments = s.split('-');
        if (segments.some(function (seg) { return seg === q; })) return 850000;
        if (s.startsWith(q)) return 800000;
        if (s.includes(q)) return 600000;
        if (d.includes(q)) return 400000;
        var tokens = q.split(/\s+/).filter(function (t) { return t.length > 0; });
        if (!tokens.length) return 0;
        var every = tokens.every(function (t) { return d.includes(t) || s.includes(t); });
        if (every) return 200000 + tokens.length * 500;
        var some = tokens.some(function (t) { return d.includes(t) || s.includes(t); });
        return some ? 50000 : 0;
      }

      function apply() {
        var raw = (input.value || '').trim().toLowerCase();
        var ranked = cards
          .map(function (el) {
            var slug = el.getAttribute('data-slug') || '';
            var desc = el.getAttribute('data-desc') || '';
            return { el: el, sc: score(slug, desc, raw) };
          })
          .filter(function (x) { return x.sc > 0; })
          .sort(function (a, b) {
            if (b.sc !== a.sc) return b.sc - a.sc;
            return (a.el.getAttribute('data-slug') || '').localeCompare(b.el.getAttribute('data-slug') || '');
          });

        cards.forEach(function (el) { el.classList.add('hidden'); });
        ranked.forEach(function (x) { x.el.classList.remove('hidden'); });

        var n = ranked.length;
        countEl.textContent = n === cards.length
          ? n + ' skills'
          : n + ' of ' + cards.length + ' skills';
        emptyEl.classList.toggle('hidden', n !== 0);
        list.classList.toggle('hidden', n === 0);
      }

      input.addEventListener('input', apply);
      input.addEventListener('search', apply);
      apply();
    })();
  </script>
</body>
</html>
