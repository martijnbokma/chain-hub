---
export const prerender = true;
import SiteHeader from '../components/SiteHeader.astro';

const base = import.meta.env.BASE_URL;

const headerNavItems = [
  { href: `${base}docs/`, label: 'Docs' },
  { href: '#how', label: 'How it works' },
  { href: '#editors', label: 'Editors' },
  { href: '#skills', label: 'Skills' },
  { href: '#commands', label: 'CLI' },
  { href: '#install', label: 'Get started', cta: true },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Chain Hub — One Source of Truth for Every AI Assistant</title>
  <meta name="description" content="chainhub.one — One Chain Hub to sync your skills, workflows, and rules across every AI editor. Curated core, your library, one symlinked home.">
  <link rel="canonical" href="https://www.chainhub.one/">
  <meta property="og:url" content="https://www.chainhub.one/">
  <meta property="og:title" content="Chain Hub — One Source of Truth for Every AI Assistant">
  <meta property="og:description" content="chainhub.one — One Chain Hub to sync skills, workflows, and rules across Claude Code, Cursor, Windsurf, Gemini CLI, and more.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body class="ch-site bg-bg text-text font-mono text-[13px] leading-[1.65] antialiased overflow-x-hidden pb-[env(safe-area-inset-bottom,0px)] [text-size-adjust:100%]">

<SiteHeader items={headerNavItems} />

<!-- ── HERO ─────────────────────────────────────────────────────── -->
<section class="relative flex min-h-dvh min-h-screen items-center overflow-hidden pt-[calc(4.5rem+env(safe-area-inset-top,0px))] sm:pt-20" id="home">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(ellipse_55%_55%_at_72%_48%,rgba(139,124,255,0.13)_0%,transparent_65%),radial-gradient(ellipse_35%_50%_at_18%_85%,rgba(72,176,255,0.07)_0%,transparent_60%)]" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute inset-0 bg-[length:64px_64px] [background-image:linear-gradient(rgba(239,242,255,0.08)_1px,transparent_1px),linear-gradient(90deg,rgba(239,242,255,0.08)_1px,transparent_1px)] [mask-image:radial-gradient(ellipse_80%_80%_at_50%_40%,black,transparent_75%)]"
    aria-hidden="true"
  ></div>
  <div class="layout-wrap relative z-10 grid w-full min-w-0 grid-cols-1 items-center gap-8 pt-8 pb-16 sm:gap-12 sm:pt-12 sm:pb-20 md:gap-[72px] md:pb-24 lg:grid-cols-2">

    <div class="min-w-0 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100 fi">
      <div class="mb-6 flex items-center gap-2.5 text-[10px] uppercase tracking-[0.18em] text-accent before:block before:h-px before:w-[22px] before:bg-accent before:content-['']">Single Source of Truth</div>
      <p class="mb-[22px] -mt-2 max-w-[440px] text-xs leading-[1.55] tracking-[0.02em] text-text-dim">
        <a href={base} class="font-semibold text-accent no-underline hover:underline hover:underline-offset-[3px]">chainhub.one</a>
        <span> — One Chain Hub to sync them all.</span>
        <span class="mt-2 block text-[11px] italic tracking-[0.01em] text-text-faint">(No magic ring required — just symlinks.)</span>
      </p>
      <h1 class="mb-6 max-w-[22ch] font-display text-[clamp(2rem,6vw+0.5rem,4.5rem)] font-bold leading-[1.02] tracking-[-0.065em] sm:leading-[0.99] sm:[max-width:none]">
        Your AI assistants,<br>
        finally <em class="not-italic text-accent">in sync.</em>
      </h1>
      <p class="mb-8 max-w-[430px] text-sm leading-[1.75] text-text-dim sm:mb-11">
        Chain Hub ships a <strong class="font-bold text-text">small, curated core</strong> — skills, workflows,
        rules, and agents to get you started. You then <strong class="font-bold text-text">grow your own library</strong>:
        scaffold skills, author rules, add workflows, and pull extras from GitHub so every
        assistant reflects <em class="not-italic text-accent">your</em> stack, language, and way of working.
      </p>
      <div class="flex w-full min-w-0 flex-col gap-3 sm:flex-row sm:flex-wrap sm:items-center sm:gap-5">
        <a href="#install" class="inline-flex min-h-11 w-full cursor-pointer items-center justify-center gap-2 rounded-sm border border-accent bg-accent px-6 py-3 font-mono text-xs font-medium tracking-[0.03em] text-bg no-underline transition-[opacity,transform] duration-200 hover:-translate-y-px hover:opacity-[0.88] sm:w-auto">
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M6.5 1v8M3 6l3.5 3.5L10 6M1.5 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Quick install
        </a>
        <a href="/docs/" class="inline-flex min-h-11 w-full cursor-pointer items-center justify-center gap-2 border border-transparent bg-transparent px-4 py-3 font-mono text-xs font-medium tracking-[0.03em] text-text-dim no-underline transition-colors hover:text-text sm:w-auto sm:justify-start sm:border-none sm:px-0 sm:py-2">
          Read docs
          <svg width="13" height="13" viewBox="0 0 13 13" fill="none" aria-hidden="true">
            <path d="M1 6.5h11M8 3l4 3.5L8 10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
      <div class="mt-11 flex flex-wrap gap-2.5 border-t border-border pt-9">
        <div class="border border-border px-3 py-1.5 text-[10px] uppercase tracking-[0.06em] text-text-dim">Broad editor support</div>
        <div class="border border-border px-3 py-1.5 text-[10px] uppercase tracking-[0.06em] text-text-dim">Core + your skills</div>
        <div class="border border-border px-3 py-1.5 text-[10px] uppercase tracking-[0.06em] text-text-dim">CLI: new, add, validate</div>
        <div class="border border-border px-3 py-1.5 text-[10px] uppercase tracking-[0.06em] text-text-dim">Self-healing symlinks</div>
        <div class="border border-border px-3 py-1.5 text-[10px] uppercase tracking-[0.06em] text-text-dim">Open format</div>
      </div>
    </div>

    <div class="fi delay-200 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100 overflow-hidden rounded-[10px] border border-border-bright bg-surface shadow-[0_48px_120px_rgba(0,0,0,0.55),0_0_0_1px_rgba(139,124,255,0.1)]" id="terminal" role="img" aria-label="Terminal showing chain setup command output">
      <div class="flex items-center gap-[7px] border-b border-border bg-surface-2 px-4 py-[11px]" aria-hidden="true">
        <div class="size-2.5 rounded-full bg-[#ff5f57]"></div>
        <div class="size-2.5 rounded-full bg-[#febc2e]"></div>
        <div class="size-2.5 rounded-full bg-[#28c840]"></div>
        <div class="min-w-0 flex-1 truncate text-center text-[10px] tracking-[0.05em] text-text-dim">terminal — ~/.chain</div>
      </div>
      <div class="min-h-[220px] px-4 py-4 text-[11.5px] leading-[1.85] sm:min-h-[268px] sm:px-6 sm:py-[22px] sm:text-[12.5px]" id="term-body" aria-hidden="true"></div>
    </div>

  </div>
</section>

<!-- ── PROBLEM ───────────────────────────────────────────────────── -->
<section class="border-y border-border bg-gradient-to-b from-surface to-transparent py-32 max-md:py-20" id="problem">
  <div class="layout-wrap">
    <div class="grid grid-cols-1 items-start gap-12 md:grid-cols-2 md:gap-20">
      <div class="fi opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-faint before:text-[rgba(139,124,255,0.62)] before:content-['//_']">The problem</div>
        <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">One machine.<br><em class="not-italic text-accent">Five configs.</em></h2>
        <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim">
          Every AI editor has its own convention for storing rules and instructions.
          You maintain the same content in five places and they drift apart the moment you update one.
        </p>
      </div>
      <div class="fi flex flex-col delay-100 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100 [&>div:last-child]:border-b-0">
        <div class="flex items-baseline gap-[18px] border-b border-border py-[22px]">
          <div class="w-5 shrink-0 text-[10px] text-text-faint">01</div>
          <div class="text-[13px] leading-[1.65] text-text-dim [&_code]:text-[12px] [&_code]:text-[rgba(139,124,255,0.62)] [&_strong]:font-normal [&_strong]:text-text">
            <strong>Cursor</strong> reads rules from <code>.cursor/rules/</code> in its own Markdown format.
          </div>
        </div>
        <div class="flex items-baseline gap-[18px] border-b border-border py-[22px]">
          <div class="w-5 shrink-0 text-[10px] text-text-faint">02</div>
          <div class="text-[13px] leading-[1.65] text-text-dim [&_code]:text-[12px] [&_code]:text-[rgba(139,124,255,0.62)] [&_strong]:font-normal [&_strong]:text-text">
            <strong>Claude Code</strong> looks in <code>~/.claude/</code> for skills and CLAUDE.md files.
          </div>
        </div>
        <div class="flex items-baseline gap-[18px] border-b border-border py-[22px]">
          <div class="w-5 shrink-0 text-[10px] text-text-faint">03</div>
          <div class="text-[13px] leading-[1.65] text-text-dim [&_code]:text-[12px] [&_code]:text-[rgba(139,124,255,0.62)] [&_strong]:font-normal [&_strong]:text-text">
            <strong>Windsurf, Gemini CLI, Trae, Kiro, Mistral Vibe</strong> — each with entirely different paths and expectations.
          </div>
        </div>
        <div class="flex items-baseline gap-[18px] border-b border-border py-[22px]">
          <div class="w-5 shrink-0 text-[10px] text-text-faint">04</div>
          <div class="text-[13px] leading-[1.65] text-text-dim [&_strong]:font-normal [&_strong]:text-text">
            The result: <strong>stale duplicates everywhere.</strong> Your best skills live in one editor only.
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── HOW IT WORKS ───────────────────────────────────────────────── -->
<section class="py-32 max-md:py-20" id="how">
  <div class="layout-wrap">
    <div class="fi mb-0 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
      <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-faint before:text-[rgba(139,124,255,0.62)] before:content-['//_']">How it works</div>
      <h2 class="mb-5 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">Write once.<br><em class="not-italic text-accent">Run everywhere.</em></h2>
      <p class="max-w-[520px] text-sm leading-[1.75] text-text-dim">
        Chain Hub maintains one canonical directory for all your AI knowledge,
        then symlinks it precisely into every editor — simultaneously.
      </p>
    </div>
    <div class="mt-[60px] grid grid-cols-1 gap-0.5 bg-border md:grid-cols-3">
      <div class="fi flex flex-col border border-border bg-surface p-8 opacity-0 translate-y-[18px] transition-[opacity,transform,border-color,background] delay-100 duration-[650ms] ease-out hover:border-[rgba(139,124,255,0.26)] hover:bg-surface-2 [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="mb-6 font-display text-[68px] font-bold leading-[0.9] tracking-[-0.08em] text-text-faint">01</div>
        <div class="mb-2.5 text-[13px] font-medium text-text">Install Chain Hub</div>
        <div class="mb-6 text-xs leading-[1.7] text-text-dim [&_a]:text-[rgba(139,124,255,0.62)] [&_a]:no-underline [&_a]:hover:underline [&_code]:text-[rgba(139,124,255,0.62)]">
          Install the published npm package globally so the
          <code>chain</code> command is available in your shell.
          To upgrade later, run the same install again, then
          <code>chain init</code> to refresh bundled core (see
          <a href="/docs/#up-to-date">docs</a>).
        </div>
        <div class="mt-auto overflow-hidden rounded-lg border border-border bg-[#060814] shadow-[inset_0_1px_0_rgba(255,255,255,0.035),0_14px_34px_rgba(0,0,0,0.18)]" aria-label="Terminal command: npm install -g chain-hub">
          <div class="flex items-center gap-1.25 border-b border-border bg-gradient-to-b from-[rgba(239,242,255,0.045)] to-[rgba(239,242,255,0.012)] px-3 py-2" aria-hidden="true">
            <span class="size-[7px] rounded-full bg-[#ff5f57]"></span>
            <span class="size-[7px] rounded-full bg-[#febc2e]"></span>
            <span class="size-[7px] rounded-full bg-[#28c840]"></span>
          </div>
          <div class="flex gap-2 overflow-x-auto whitespace-nowrap px-3.5 py-3 text-xs leading-[1.45]">
            <span class="shrink-0 text-accent">$</span>
            <span class="text-text">npm install -g chain-hub</span>
          </div>
        </div>
      </div>
      <div class="fi flex flex-col border border-border bg-surface p-8 opacity-0 translate-y-[18px] transition-[opacity,transform,border-color,background] delay-200 duration-[650ms] ease-out hover:border-[rgba(139,124,255,0.26)] hover:bg-surface-2 [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="mb-6 font-display text-[68px] font-bold leading-[0.9] tracking-[-0.08em] text-text-faint">02</div>
        <div class="mb-2.5 text-[13px] font-medium text-text">Initialize your hub</div>
        <div class="mb-6 text-xs leading-[1.7] text-text-dim [&_code]:text-[rgba(139,124,255,0.62)]">
          Run <code>chain init</code> to install the protected
          <code>core/</code> into your <code>CHAIN_HOME</code>.
        </div>
        <div class="mt-auto overflow-hidden rounded-lg border border-border bg-[#060814] shadow-[inset_0_1px_0_rgba(255,255,255,0.035),0_14px_34px_rgba(0,0,0,0.18)]" aria-label="Terminal command: chain init">
          <div class="flex items-center gap-1.25 border-b border-border bg-gradient-to-b from-[rgba(239,242,255,0.045)] to-[rgba(239,242,255,0.012)] px-3 py-2" aria-hidden="true">
            <span class="size-[7px] rounded-full bg-[#ff5f57]"></span>
            <span class="size-[7px] rounded-full bg-[#febc2e]"></span>
            <span class="size-[7px] rounded-full bg-[#28c840]"></span>
          </div>
          <div class="flex gap-2 overflow-x-auto whitespace-nowrap px-3.5 py-3 text-xs leading-[1.45]">
            <span class="shrink-0 text-accent">$</span>
            <span class="text-text">chain init</span>
          </div>
        </div>
      </div>
      <div class="fi flex flex-col border border-border bg-surface p-8 opacity-0 translate-y-[18px] transition-[opacity,transform,border-color,background] delay-300 duration-[650ms] ease-out hover:border-[rgba(139,124,255,0.26)] hover:bg-surface-2 [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="mb-6 font-display text-[68px] font-bold leading-[0.9] tracking-[-0.08em] text-text-faint">03</div>
        <div class="mb-2.5 text-[13px] font-medium text-text">Run setup and sync</div>
        <div class="mb-6 text-xs leading-[1.7] text-text-dim [&_code]:text-[rgba(139,124,255,0.62)]">
          Run <code>chain setup</code> once to detect installed IDEs and create symlinks.
          Then maintain your playbooks in <code>skills/</code>,
          <code>workflows/</code>, and <code>rules/</code>.
        </div>
        <div class="mt-auto overflow-hidden rounded-lg border border-border bg-[#060814] shadow-[inset_0_1px_0_rgba(255,255,255,0.035),0_14px_34px_rgba(0,0,0,0.18)]" aria-label="Terminal command: chain setup">
          <div class="flex items-center gap-1.25 border-b border-border bg-gradient-to-b from-[rgba(239,242,255,0.045)] to-[rgba(239,242,255,0.012)] px-3 py-2" aria-hidden="true">
            <span class="size-[7px] rounded-full bg-[#ff5f57]"></span>
            <span class="size-[7px] rounded-full bg-[#febc2e]"></span>
            <span class="size-[7px] rounded-full bg-[#28c840]"></span>
          </div>
          <div class="flex gap-2 overflow-x-auto whitespace-nowrap px-3.5 py-3 text-xs leading-[1.45]">
            <span class="shrink-0 text-accent">$</span>
            <span class="text-text">chain setup</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ── EDITORS ────────────────────────────────────────────────────── -->
<section
  class="border-y border-border bg-[radial-gradient(ellipse_42%_36%_at_78%_26%,rgba(139,124,255,0.08),transparent_68%),linear-gradient(180deg,#0c0f1a,#070912)] py-32 max-md:py-20"
  id="editors"
>
  <div class="layout-wrap">
    <div class="fi mb-14 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
      <div>
        <div class="mb-3.5 text-[10px] uppercase tracking-[0.2em] text-text-faint before:text-[rgba(139,124,255,0.62)] before:content-['//_']">Supported editors</div>
        <h2 class="mb-0 font-display text-[clamp(30px,3.5vw,50px)] font-bold leading-[1.02] tracking-[-0.06em]">Works where<br><em class="not-italic text-accent">you work.</em></h2>
        <p class="mt-5 max-w-[520px] text-sm leading-[1.75] text-text-dim">
          Targets the environments people use most. <strong class="font-semibold text-text">chain setup</strong> only links editors
          it detects on your machine — you grow skills and rules in the hub; the CLI wires them through.
        </p>
      </div>
    </div>
    <div class="fi grid gap-3 delay-100 opacity-0 [grid-template-columns:repeat(auto-fit,minmax(min(100%,148px),1fr))] translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
      <a class="group relative flex min-h-[172px] flex-col items-center justify-center gap-3.5 overflow-hidden rounded-[18px] border border-border bg-gradient-to-b from-white/[0.035] to-surface px-[18px] pb-[22px] pt-7 text-center text-inherit no-underline transition-[transform,border-color,background,box-shadow] duration-[220ms] hover:-translate-y-0.5 hover:border-[rgba(139,124,255,0.26)] hover:bg-gradient-to-b hover:from-[rgba(139,124,255,0.08)] hover:to-surface-2 hover:shadow-[0_22px_60px_rgba(0,0,0,0.28)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent before:pointer-events-none before:absolute before:inset-0 before:bg-[radial-gradient(circle_at_50%_0%,rgba(139,124,255,0.16),transparent_58%)] before:opacity-0 before:transition-opacity before:duration-[220ms] before:content-[''] hover:before:opacity-100 focus-visible:before:opacity-100" href="https://www.anthropic.com/claude-code" target="_blank" rel="noopener noreferrer" aria-label="Open Claude Code in a new tab">
        <div class="relative z-10 flex size-[62px] items-center justify-center rounded-[18px] border border-border-bright bg-[rgba(239,242,255,0.045)] shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] transition-[transform,border-color,background] duration-[220ms] group-hover:scale-[1.04] group-hover:border-[rgba(139,124,255,0.26)] group-hover:bg-[rgba(139,124,255,0.095)]" aria-hidden="true">
          <img class="size-9 object-contain" src="/assets/logos/claude-code.svg" alt="" loading="lazy" decoding="async">
        </div>
        <div class="relative z-10 text-xs tracking-[-0.02em] text-text">Claude Code</div>
        <div class="relative z-10 rounded-full border border-green/20 bg-green/10 px-2 py-0.5 text-[9px] uppercase tracking-[0.08em] text-green">Live</div>
      </a>
      <a class="group relative flex min-h-[172px] flex-col items-center justify-center gap-3.5 overflow-hidden rounded-[18px] border border-border bg-gradient-to-b from-white/[0.035] to-surface px-[18px] pb-[22px] pt-7 text-center text-inherit no-underline transition-[transform,border-color,background,box-shadow] duration-[220ms] hover:-translate-y-0.5 hover:border-[rgba(139,124,255,0.26)] hover:bg-gradient-to-b hover:from-[rgba(139,124,255,0.08)] hover:to-surface-2 hover:shadow-[0_22px_60px_rgba(0,0,0,0.28)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-accent before:pointer-events-none before:absolute before:inset-0 before:bg-[radial-gradient(circle_at_50%_0%,rgba(139,124,255,0.16),transparent_58%)] before:opacity-0 before:transition-opacity before:duration-[220ms] before:content-[''] hover:before:opacity-100 focus-visible:before:opacity-100" href="https://cursor.com/" target="_blank" rel="noopener noreferrer" aria-label="Open Cursor in a new tab">
        <div class="relative z-10 flex size-[62px] items-center justify-center rounded-[18px] border border-border-bright bg-[rgba(239,242,255,0.045)] shadow-[inset_0_1px_0_rgba(255,255,255,0.05)] transition-[transform,border-color,background] duration-[220ms] group-hover:scale-[1.04] group-hover:border-[rgba(139,124,255,0.26)] group-hover:bg-[rgba(139,124,255,0.095)]" aria-hidden="true">
          <img class="size-9 object-contain" src="/assets/logos/cursor.svg" alt="" loading="lazy" decoding="async">
        </div>
        <div class="relative z-10 text-xs tracking-[-0.02em] text-text">Cursor</div>
