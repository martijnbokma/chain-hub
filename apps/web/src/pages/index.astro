---
export const prerender = true;
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Editors from '../components/sections/Editors.astro';
import SkillsAnatomy from '../components/sections/SkillsAnatomy.astro';
import CliReference from '../components/sections/CliReference.astro';
import Install from '../components/sections/Install.astro';
import Footer from '../components/sections/Footer.astro';

const base = import.meta.env.BASE_URL;

const headerNavItems = [
  { href: `${base}docs/`, label: 'Docs' },
  { href: '#how', label: 'How it works' },
  { href: '#editors', label: 'Editors' },
  { href: '#skills', label: 'Skills' },
  { href: '#commands', label: 'CLI' },
  { href: '#install', label: 'Get started', cta: true },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Chain Hub — One Source of Truth for Every AI Assistant</title>
  <meta name="description" content="chainhub.one — One Chain Hub to sync your skills, workflows, and rules across every AI editor. Curated core, your library, one symlinked home.">
  <link rel="canonical" href="https://www.chainhub.one/">
  <meta property="og:url" content="https://www.chainhub.one/">
  <meta property="og:title" content="Chain Hub — One Source of Truth for Every AI Assistant">
  <meta property="og:description" content="chainhub.one — One Chain Hub to sync skills, workflows, and rules across Claude Code, Cursor, Windsurf, Gemini CLI, and more.">
  <meta property="og:type" content="website">
  <meta name="twitter:card" content="summary_large_image">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:wght@500;600;700&family=JetBrains+Mono:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body class="ch-site bg-bg text-text font-mono text-[13px] leading-[1.65] antialiased overflow-x-hidden pb-[env(safe-area-inset-bottom,0px)] [text-size-adjust:100%]">

<SiteHeader items={headerNavItems} />

<Hero base={base} />
<Problem />
<HowItWorks />
<Editors />
<SkillsAnatomy />
<CliReference />
<Install />
<Footer base={base} />

<script is:inline>
  const nav = document.getElementById('nav');
  function syncNav() {
    if (!nav) return;
    if (window.scrollY > 36) nav.setAttribute('data-scrolled', 'true');
    else nav.removeAttribute('data-scrolled');
  }
  syncNav();
  window.addEventListener('scroll', syncNav, { passive: true });

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fi').forEach(function (el) { io.observe(el); });

  var termLine =
    'flex items-baseline gap-2 opacity-0 translate-y-[3px] transition-[opacity,transform] duration-[280ms]';
  var termIndent =
    'pl-4 opacity-0 translate-y-[3px] transition-[opacity,transform] duration-[280ms]';
  var termShown = 'opacity-100 translate-y-0';

  var termScript = [
    { type: 'cmd',   text: 'chain setup' },
    { type: 'out',   text: '  Scanning for installed IDEs…', cls: 'text-text-dim' },
    { type: 'out',   text: '  ✓  Claude Code   →  ~/.claude/skills', cls: 'text-green' },
    { type: 'out',   text: '  ✓  Cursor        →  ~/.cursor/rules',  cls: 'text-green' },
    { type: 'out',   text: '  ✓  Windsurf      →  ~/.codeium/windsurf', cls: 'text-green' },
    { type: 'out',   text: '  ✓  Gemini CLI    →  ~/.gemini/skills', cls: 'text-green' },
    { type: 'out',   text: '  ✓  Kiro          →  ~/.kiro/skills',   cls: 'text-green' },
    { type: 'out',   text: '  ✓  Trae          →  ~/.trae/skills',   cls: 'text-green' },
    { type: 'out',   text: '  ✓  Mistral Vibe  →  ~/.vibe/skills', cls: 'text-green' },
    { type: 'blank' },
    { type: 'out',   text: '  Hub linked. Core + symlinks ready — build your library (chain new, chain add …).', cls: 'text-accent' },
    { type: 'cur' },
  ];

  var termBody = document.getElementById('term-body');
  var termIdx  = 0;

  function makeSpan(cls, text) {
    var s = document.createElement('span');
    s.className = cls;
    s.textContent = text;
    return s;
  }

  function renderTermLine(item) {
    var el = document.createElement('div');
    if (item.type === 'cmd') {
      el.className = termLine;
      el.appendChild(makeSpan('shrink-0 text-accent', '$'));
      el.appendChild(makeSpan('inline-flex items-baseline text-text', ' ' + item.text));
    } else if (item.type === 'cur') {
      el.className = termLine;
      el.appendChild(makeSpan('shrink-0 text-accent', '$'));
      el.appendChild(makeSpan('inline-flex items-baseline text-text', ' '));
      var cur = document.createElement('span');
      cur.className = 'inline-block h-[1.05em] w-[0.55ch] translate-y-px bg-accent animate-blink';
      el.appendChild(cur);
    } else if (item.type === 'blank') {
      el.className = termIndent + ' h-2';
    } else {
      el.className = termIndent;
      el.appendChild(makeSpan(item.cls, item.text));
    }
    termBody.appendChild(el);
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        termShown.split(' ').forEach(function (c) { el.classList.add(c); });
      });
    });
  }

  function termTick() {
    if (termIdx >= termScript.length) return;
    renderTermLine(termScript[termIdx++]);
    var delay = termIdx === 1 ? 700 : termScript[termIdx - 1].type === 'cmd' ? 320 : 155;
    setTimeout(termTick, delay);
  }

  setTimeout(termTick, 560);

  var navMenu = document.getElementById('nav-menu');
  if (navMenu) {
    navMenu.querySelectorAll('ul a').forEach(function (a) {
      a.addEventListener('click', function () { navMenu.removeAttribute('open'); });
    });
  }

  document.getElementById('copy-btn').addEventListener('click', function () {
    var code = [
      '# Docs: https://www.chainhub.one/',
      '',
      '# 1. Install Chain Hub globally',
      'npm install -g chain-hub',
      '',
      '# 2. Initialize your hub',
      'chain init',
      '',
      '# 3. Sync all your AI editors in one shot',
      'chain setup',
    ].join('\n');
    var btn = this;
    navigator.clipboard.writeText(code).then(function () {
      btn.textContent = 'copied ✓';
      setTimeout(function () { btn.textContent = 'copy'; }, 2200);
    });
  });
</script>
</body>
</html>
