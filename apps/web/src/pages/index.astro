---
export const prerender = true;
import { buildHomePageTerminalScriptItems } from 'chain-setup-display-paths';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/sections/Hero.astro';
import Problem from '../components/sections/Problem.astro';
import Comparison from '../components/sections/Comparison.astro';
import UseCases from '../components/sections/UseCases.astro';
import LibraryPreview from '../components/sections/LibraryPreview.astro';
import SimpleText from '../components/sections/SimpleText.astro';
import HowItWorks from '../components/sections/HowItWorks.astro';
import Editors from '../components/sections/Editors.astro';
import SkillsAnatomy from '../components/sections/SkillsAnatomy.astro';
import CliReference from '../components/sections/CliReference.astro';
import Install from '../components/sections/Install.astro';
import Faq from '../components/sections/Faq.astro';
import Footer from '../components/sections/Footer.astro';
import SeoHead from '../components/SeoHead.astro';

const base = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.origin ?? 'https://www.chainhub.one';

const pageTitle = 'Chain Hub | One brain for all your AI assistants';
const pageDescription =
  'Chain Hub connects your AI tools to a single source of knowledge. Sync your expert instructions, brand voice, and custom skills across Claude Code, Cursor, Windsurf, Gemini CLI, Antigravity, Kiro, Trae, Mistral Vibe, and more.';

const ogImageObject = {
  '@type': 'ImageObject',
  url: `${siteOrigin}/og.png`,
  width: 1200,
  height: 630,
};

const homeTermScriptItems = buildHomePageTerminalScriptItems();

const homeJsonLd: Record<string, unknown>[] = [
  {
    '@type': 'WebSite',
    name: 'Chain Hub',
    url: `${siteOrigin}/`,
    description: pageDescription,
    inLanguage: 'en',
    image: ogImageObject,
    publisher: {
      '@type': 'Organization',
      name: 'Chain Hub',
      url: siteOrigin,
    },
  },
  {
    '@type': 'SoftwareApplication',
    name: 'Chain Hub CLI',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Windows, macOS, Linux',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
    downloadUrl: 'https://www.npmjs.com/package/chain-hub',
  },
];

const headerNavItems = [
  { href: `${base}docs/`, label: 'Docs' },
  { href: '#comparison', label: 'Why?' },
  { href: '#use-cases', label: 'Use Cases' },
  { href: '#text-first', label: 'Simplicity' },
  { href: '#faq', label: 'FAQ' },
  { href: '#install', label: 'Get started', cta: true },
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SeoHead
    title={pageTitle}
    description={pageDescription}
    path="/"
    ogType="website"
    jsonLd={homeJsonLd}
  />
</head>
<body class="ch-site bg-bg text-text font-mono text-[13px] leading-[1.65] antialiased overflow-x-hidden pb-[env(safe-area-inset-bottom,0px)] [text-size-adjust:100%]">

<SiteHeader items={headerNavItems} />

<Hero />
<Problem />
<Comparison />
<UseCases />
<LibraryPreview />
<SimpleText />
<HowItWorks />
<Editors />
<SkillsAnatomy />
<CliReference />
<Install />
<Faq />
<Footer />

<script is:inline type="application/json" id="chain-home-term-json" set:html={JSON.stringify(homeTermScriptItems)}></script>
<script is:inline>
  const nav = document.getElementById('nav');
  function syncNav() {
    if (!nav) return;
    if (window.scrollY > 36) nav.setAttribute('data-scrolled', 'true');
    else nav.removeAttribute('data-scrolled');
  }
  syncNav();
  window.addEventListener('scroll', syncNav, { passive: true });

  var io = new IntersectionObserver(function (entries) {
    entries.forEach(function (e) {
      if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
    });
  }, { threshold: 0.08 });
  document.querySelectorAll('.fi').forEach(function (el) { io.observe(el); });

  var termLine =
    'flex items-baseline gap-2 opacity-0 translate-y-[3px] transition-[opacity,transform] duration-[280ms]';
  var termIndent =
    'pl-4 opacity-0 translate-y-[3px] transition-[opacity,transform] duration-[280ms]';
  var termShown = 'opacity-100 translate-y-0';

  var termJson = document.getElementById('chain-home-term-json');
  var termScript = termJson ? JSON.parse(termJson.textContent || '[]') : [];
  if (!termScript.length) {
    termScript = [
      { type: 'cmd', text: 'chain setup' },
      { type: 'out', text: '  (Install block could not load terminal preview.)', cls: 'text-text-dim' },
      { type: 'cur' },
    ];
  }

  var termBody = document.getElementById('term-body');
  var termIdx  = 0;

  function makeSpan(cls, text) {
    var s = document.createElement('span');
    s.className = cls;
    s.textContent = text;
    return s;
  }

  function renderTermLine(item) {
    var el = document.createElement('div');
    if (item.type === 'cmd') {
      el.className = termLine;
      el.appendChild(makeSpan('shrink-0 text-accent', '$'));
      el.appendChild(makeSpan('inline-flex items-baseline text-text', ' ' + item.text));
    } else if (item.type === 'cur') {
      el.className = termLine;
      el.appendChild(makeSpan('shrink-0 text-accent', '$'));
      el.appendChild(makeSpan('inline-flex items-baseline text-text', ' '));
      var cur = document.createElement('span');
      cur.className = 'inline-block h-[1.05em] w-[0.55ch] translate-y-px bg-accent animate-blink';
      el.appendChild(cur);
    } else if (item.type === 'blank') {
      el.className = termIndent + ' h-2';
    } else {
      el.className = termIndent;
      el.appendChild(makeSpan(item.cls, item.text));
    }
    termBody.appendChild(el);
    requestAnimationFrame(function () {
      requestAnimationFrame(function () {
        termShown.split(' ').forEach(function (c) { el.classList.add(c); });
      });
    });
  }

  function termTick() {
    if (termIdx >= termScript.length) return;
    renderTermLine(termScript[termIdx++]);
    var delay = termIdx === 1 ? 700 : termScript[termIdx - 1].type === 'cmd' ? 320 : 155;
    setTimeout(termTick, delay);
  }

  setTimeout(termTick, 560);

  var navMenu = document.getElementById('nav-menu');
  if (navMenu) {
    navMenu.querySelectorAll('ul a').forEach(function (a) {
      a.addEventListener('click', function () { navMenu.removeAttribute('open'); });
    });
  }

  document.getElementById('copy-btn').addEventListener('click', function () {
    var code = [
      '# Docs: https://www.chainhub.one/',
      '',
      '# 1. Install Chain Hub globally',
      'npm install -g chain-hub',
      '',
      '# 2. Initialize your hub',
      'chain init',
      '',
      '# 3. Sync all your AI editors in one shot',
      'chain setup',
    ].join('\n');
    var btn = this;
    navigator.clipboard.writeText(code).then(function () {
      btn.textContent = 'copied ✓';
      setTimeout(function () { btn.textContent = 'copy'; }, 2200);
    });
  });
</script>
</body>
</html>
