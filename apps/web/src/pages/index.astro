      <div class="fi min-w-0 overflow-hidden rounded-md border border-border-bright bg-surface delay-100 opacity-0 translate-y-[18px] transition-[opacity,transform] duration-[650ms] ease-out [&.in]:translate-y-0 [&.in]:opacity-100">
        <div class="flex min-w-0 items-center justify-between gap-3 border-b border-border bg-surface-2 px-4 py-3 sm:px-[18px] sm:py-[11px]">
          <span class="min-w-0 truncate text-[10px] uppercase tracking-[0.07em] text-text-dim">bash</span>
          <button class="inline-flex min-h-9 min-w-9 shrink-0 cursor-pointer items-center justify-center rounded-md border-none bg-transparent font-mono text-[10px] tracking-[0.05em] text-text-faint transition-colors hover:text-accent" id="copy-btn" type="button">copy</button>
