---
export const prerender = true;
import SiteHeader from '../../components/SiteHeader.astro';
import Footer from '../../components/sections/Footer.astro';
import SeoHead from '../../components/SeoHead.astro';
import {
  getEditorFeedbackDiscussionsUrl,
  getEditorFeedbackFormUrl,
} from '../../lib/editor-feedback-links';
import DocLayout from '../../components/docs/DocLayout.astro';
import DocIntro from '../../components/docs/DocIntro.astro';
import DocWhatIsASkill from '../../components/docs/DocWhatIsASkill.astro';
import DocFirstSkill from '../../components/docs/DocFirstSkill.astro';
import DocHubLayout from '../../components/docs/DocHubLayout.astro';
import DocEditorSetup from '../../components/docs/DocEditorSetup.astro';
import DocQuickstart from '../../components/docs/DocQuickstart.astro';
import DocLocation from '../../components/docs/DocLocation.astro';
import DocAddingKnowledge from '../../components/docs/DocAddingKnowledge.astro';
import DocCoreConcepts from '../../components/docs/DocCoreConcepts.astro';
import DocContinualLearning from '../../components/docs/DocContinualLearning.astro';
import DocCommandOverview from '../../components/docs/DocCommandOverview.astro';
import DocLocalDev from '../../components/docs/DocLocalDev.astro';
import DocTroubleshooting from '../../components/docs/DocTroubleshooting.astro';

const baseUrl = import.meta.env.BASE_URL;
const siteOrigin = Astro.site?.origin ?? 'https://www.chainhub.one';

const editorFeedbackDiscussionsUrl = getEditorFeedbackDiscussionsUrl();
const editorFeedbackFormUrl = getEditorFeedbackFormUrl();

const pageTitle = 'Chain Hub documentation | CLI, CHAIN_HOME & quickstart';
const pageDescription =
  'Official Chain Hub docs: install the chain-hub npm CLI, run chain init and chain setup, learn the CHAIN_HOME layout, browse commands (add, validate, list), and local development.';

const docsJsonLd: Record<string, unknown>[] = [
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: `${siteOrigin}/` },
      { '@type': 'ListItem', position: 2, name: 'Documentation', item: `${siteOrigin}/docs/` },
    ],
  },
  {
    '@type': 'WebPage',
    name: pageTitle,
    description: pageDescription,
    url: `${siteOrigin}/docs/`,
    inLanguage: 'en',
    primaryImageOfPage: {
      '@type': 'ImageObject',
      url: `${siteOrigin}/og.png`,
      width: 1200,
      height: 630,
    },
    isPartOf: { '@type': 'WebSite', name: 'Chain Hub', url: `${siteOrigin}/` },
  },
];

const headerNavItems = [
  { href: '#quickstart', label: 'Quickstart' },
  { href: '#what-is-a-skill', label: 'Skills' },
  { href: '#up-to-date', label: 'Updates' },
  { href: '#location', label: 'Location' },
  { href: '#install-content', label: 'Content', mobileLabel: 'Content types' },
  { href: '#concepts', label: 'Concepts' },
  { href: '#continual-learning', label: 'Learning loop' },
  { href: '#commands', label: 'Commands' },
  { href: '#local-dev', label: 'Local dev' },
  { href: '#troubleshooting', label: 'Troubleshooting', cta: true },
];

const headerMobilePrefix = [
  { href: baseUrl, label: 'Home' },
  { href: `${baseUrl}registry/`, label: 'Registry' },
];

const tocItems = [
  { href: '#intro', label: 'New to Chain Hub?' },
  { href: '#what-is-a-skill', label: 'What is a skill?' },
  { href: '#first-skill', label: 'Your first skill' },
  { href: '#hub-layout', label: 'Hub layout' },
  { href: '#editor-setup', label: 'Editor setup' },
  { href: '#quickstart', label: 'Quickstart' },
  { href: '#up-to-date', label: 'Keeping your Hub up to date' },
  { href: '#location', label: 'Where is your Hub located?' },
  { href: '#install-content', label: 'Adding Knowledge' },
  { href: '#concepts', label: 'Core concepts' },
  { href: '#continual-learning', label: 'Continual learning' },
  { href: '#commands', label: 'Command overview' },
  { href: '#local-dev', label: 'Local development' },
  { href: '#troubleshooting', label: 'Troubleshooting' },
] as const;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <SeoHead
    title={pageTitle}
    description={pageDescription}
    path="/docs/"
    ogType="website"
    jsonLd={docsJsonLd}
    ogImageAlt="Chain Hub documentation — CLI, CHAIN_HOME, install and commands"
  />
</head>
<body class="ch-site min-w-0 overflow-x-hidden bg-bg pb-[env(safe-area-inset-bottom,0px)] font-mono text-[13px] leading-[1.65] text-text antialiased [text-size-adjust:100%]">

<SiteHeader items={headerNavItems} mobilePrefix={headerMobilePrefix} desktopNavMode="menu" />

<DocLayout tocItems={tocItems}>
  <DocIntro />
  <DocWhatIsASkill />
  <DocFirstSkill />
  <DocHubLayout />
  <DocEditorSetup editorFeedbackDiscussionsUrl={editorFeedbackDiscussionsUrl} editorFeedbackFormUrl={editorFeedbackFormUrl} />
  <DocQuickstart />
  <DocLocation />
  <DocAddingKnowledge />
  <DocCoreConcepts />
  <DocContinualLearning />
  <DocCommandOverview />
  <DocLocalDev />
  <DocTroubleshooting />
  <Footer slot="footer" layoutClass="layout-wrap-docs" compact />
</DocLayout>

<script is:inline>
  const nav = document.getElementById('nav');
  function syncNavDocs() {
    if (!nav) return;
    if (window.scrollY > 36) nav.setAttribute('data-scrolled', 'true');
    else nav.removeAttribute('data-scrolled');
  }
  syncNavDocs();
  window.addEventListener('scroll', syncNavDocs, { passive: true });

  const navMenu = document.getElementById('nav-menu');
  if (navMenu) {
    navMenu.querySelectorAll('ul a').forEach(function (a) {
      a.addEventListener('click', function () { navMenu.removeAttribute('open'); });
    });
  }

  const docsTocMobile = document.getElementById('docs-toc-mobile');
  if (docsTocMobile) {
    docsTocMobile.querySelectorAll('a[href^="#"]').forEach(function (a) {
      a.addEventListener('click', function () {
        docsTocMobile.removeAttribute('open');
      });
    });
  }
</script>
</body>
</html>
