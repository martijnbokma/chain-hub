{
  "name": "@chain-hub/hub-ui",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "astro build",
    "dev": "concurrently -k -n hub,astro -c magenta,cyan \"bun run dev:hub\" \"bun run dev:astro\"",
    "dev:astro": "astro dev --host 127.0.0.1 --port 4321",
    "dev:hub": "bun ../../cli/chain.ts hub --port 2342",
    "preview": "astro preview --host 127.0.0.1 --port 4321"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "astro": "^6.2.2",
    "tailwindcss": "^4.2.4"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "concurrently": "^9.2.0",
    "typescript": "^6.0.3"
  }
}
